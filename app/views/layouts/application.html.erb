<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-bs-theme="light">
  <head>
    <title><%= content_for(:title) || t('app_name') %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", media: "all" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="<%= content_for?(:body_class) ? yield(:body_class) : "" %>">

    <%= render "layouts/header" %>

    <div class="main-wrapper">

      <% if notice.present? %>
        <div class="px-3 pt-3">
          <div class="alert alert-success alert-dismissible fade show mb-0" role="alert">
            <%= notice %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="px-3 pt-3">
          <div class="alert alert-danger alert-dismissible fade show mb-0" role="alert">
            <%= alert %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        </div>
      <% end %>

      <%= yield %>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Dark mode — apply saved theme immediately
      (function() {
        var saved = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-bs-theme', saved);
      })();

      function initBootstrapComponents() {
        document.querySelectorAll('[data-bs-toggle="dropdown"]').forEach(function(el) {
          try { var inst = bootstrap.Dropdown.getInstance(el); if (inst) inst.dispose(); } catch(e) {}
          new bootstrap.Dropdown(el);
        });
        document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(function(el) {
          try { var inst = bootstrap.Collapse.getInstance(el); if (inst) inst.dispose(); } catch(e) {}
          new bootstrap.Collapse(el, { toggle: false });
        });
        var theme = document.documentElement.getAttribute('data-bs-theme') || 'light';
        var cls = theme === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
        document.querySelectorAll('#darkModeToggle i, #darkModeToggleMobile i').forEach(function(i) {
          i.className = cls;
        });
      }

      if (!window._navInitBound) {
        window._navInitBound = true;

        document.addEventListener('turbo:load', function() {
          requestAnimationFrame(initBootstrapComponents);
        });
        document.addEventListener('turbo:render', function() {
          requestAnimationFrame(initBootstrapComponents);
        });

        document.addEventListener('click', function(e) {
          var btn = e.target.closest('#darkModeToggle, #darkModeToggleMobile');
          if (!btn) return;
          var next = document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-bs-theme', next);
          localStorage.setItem('theme', next);
          var cls = next === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
          document.querySelectorAll('#darkModeToggle i, #darkModeToggleMobile i').forEach(function(i) {
            i.className = cls;
          });
        });
      }
    </script>
  </body>
</html>
