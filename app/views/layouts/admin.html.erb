<!DOCTYPE html>
<html lang="<%= I18n.locale %>" data-bs-theme="light">
  <head>
    <title>Admin · <%= content_for(:title) || t('app_name') %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", media: "all" %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      (function() {
        var saved = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-bs-theme', saved);
      })();
    </script>
  </head>
  <body class="admin-body">

    <div id="admin-layout">

      <%# ── Admin Sidebar ── %>
      <aside id="admin-sidebar">
        <div id="admin-sb-inner">

          <%# Brand %>
          <div id="admin-sb-brand">
            <i class="bi bi-shield-lock-fill text-danger"></i>
            <span>Admin Panel</span>
          </div>

          <%# Navigation %>
          <nav id="admin-sb-nav">

            <span class="admin-sb-label"><%= t('admin.nav_overview') %></span>
            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/dashboard' %>"
               href="<%= admin_root_path %>">
              <i class="bi bi-grid-fill"></i><span><%= t('admin.dashboard') %></span>
            </a>

            <span class="admin-sb-sep"></span>
            <span class="admin-sb-label"><%= t('admin.nav_catalog') %></span>

            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/items' %>"
               href="<%= admin_items_path %>">
              <i class="bi bi-box-seam"></i><span><%= t('nav.items') %></span>
            </a>
            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/categories' %>"
               href="<%= admin_categories_path %>">
              <i class="bi bi-grid-3x3-gap"></i><span><%= t('nav.categories') %></span>
            </a>
            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/effects' %>"
               href="<%= admin_effects_path %>">
              <i class="bi bi-stars"></i><span><%= t('nav.effects') %></span>
            </a>
            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/rarities' %>"
               href="<%= admin_rarities_path %>">
              <i class="bi bi-gem"></i><span><%= t('nav.rarities') %></span>
            </a>
            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/weapons' %>"
               href="<%= admin_weapons_path %>">
              <i class="bi bi-hammer"></i><span><%= t('nav.weapons') %></span>
            </a>
            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/armors' %>"
               href="<%= admin_armors_path %>">
              <i class="bi bi-shield-fill"></i><span><%= t('nav.armors') %></span>
            </a>

            <span class="admin-sb-sep"></span>
            <span class="admin-sb-label"><%= t('admin.nav_adventure') %></span>

            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/parties' %>"
               href="<%= admin_parties_path %>">
              <i class="bi bi-shield-fill"></i><span><%= t('nav.parties') %></span>
            </a>
            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/characters' %>"
               href="<%= admin_characters_path %>">
              <i class="bi bi-person-badge"></i><span><%= t('nav.characters') %></span>
            </a>
            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/character_classes' %>"
               href="<%= admin_character_classes_path %>">
              <i class="bi bi-shield-shaded"></i><span><%= t('character_classes.title') %></span>
            </a>

            <span class="admin-sb-sep"></span>
            <span class="admin-sb-label"><%= t('admin.nav_lore') %></span>

            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/lore_entries' %>"
               href="<%= admin_lore_entries_path %>">
              <i class="bi bi-book"></i><span><%= t('nav.lore') %></span>
            </a>

            <span class="admin-sb-sep"></span>
            <span class="admin-sb-label"><%= t('admin.nav_users') %></span>

            <a class="admin-sb-link <%= 'active' if controller_path == 'admin/users' %>"
               href="<%= admin_users_path %>">
              <i class="bi bi-people"></i><span><%= t('admin.manage_users') %></span>
            </a>

          </nav>

          <%# Footer %>
          <div id="admin-sb-foot">
            <a href="<%= root_path %>" class="admin-sb-foot-link">
              <i class="bi bi-arrow-left-circle"></i><span><%= t('admin.back_to_app') %></span>
            </a>
          </div>

        </div>
      </aside>

      <%# ── Main Content ── %>
      <div id="admin-main">

        <%# Top bar %>
        <div id="admin-topbar">
          <div class="admin-topbar-left">
            <% if content_for?(:admin_breadcrumb) %>
              <%= yield :admin_breadcrumb %>
            <% else %>
              <span class="text-muted small"><%= t('admin.admin_panel') %></span>
            <% end %>
          </div>
          <div class="admin-topbar-right">
            <span class="text-muted small d-none d-md-inline"><%= current_user.full_name %></span>
            <% if current_user.has_avatar? %>
              <% if current_user.avatar.attached? %>
                <%= image_tag current_user.avatar, class: "rounded-circle", width: 26, height: 26, style: "object-fit:cover;" %>
              <% else %>
                <img src="<%= current_user.avatar_url %>" class="rounded-circle" width="26" height="26" style="object-fit:cover;">
              <% end %>
            <% else %>
              <div class="rounded-circle bg-danger bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:26px;height:26px;">
                <span style="font-size:0.55rem;font-weight:700;" class="text-danger"><%= current_user.initials %></span>
              </div>
            <% end %>
            <button id="adminDarkToggle" title="Toggle theme">
              <i class="bi bi-moon-fill"></i>
            </button>
          </div>
        </div>

        <%# Flash messages %>
        <% if notice.present? %>
          <div class="admin-flash admin-flash-success" role="alert">
            <span><i class="bi bi-check-circle me-2"></i><%= notice %></span>
            <button type="button" onclick="this.parentElement.remove()" class="admin-flash-close"><i class="bi bi-x"></i></button>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="admin-flash admin-flash-danger" role="alert">
            <span><i class="bi bi-exclamation-triangle me-2"></i><%= alert %></span>
            <button type="button" onclick="this.parentElement.remove()" class="admin-flash-close"><i class="bi bi-x"></i></button>
          </div>
        <% end %>

        <%# Page Content %>
        <div id="admin-content">
          <%= yield %>
        </div>

      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      // Dark mode toggle
      (function() {
        var saved = localStorage.getItem('theme') || 'light';
        var cls = saved === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
        var i = document.querySelector('#adminDarkToggle i');
        if (i) i.className = cls;
      })();

      document.addEventListener('click', function(e) {
        var btn = e.target.closest('#adminDarkToggle');
        if (!btn) return;
        var next = document.documentElement.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-bs-theme', next);
        localStorage.setItem('theme', next);
        var i = btn.querySelector('i');
        if (i) i.className = next === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
      });
    </script>
  </body>
</html>
