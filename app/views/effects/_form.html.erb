<%= form_with(model: @effect, local: true) do |form| %>
  <% if @effect.errors.any? %>
    <div class="alert alert-danger py-2 small">
      <i class="bi bi-exclamation-triangle me-1"></i>
      <strong><%= pluralize(@effect.errors.count, "error") %>:</strong>
      <ul class="mb-0 mt-1">
        <% @effect.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="mb-3">
        <%= form.label :name, t('shared.name'), class: "form-label small fw-semibold" %>
        <%= form.text_field :name, class: "form-control form-control-sm", placeholder: "Effect name" %>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-sm-6">
          <%= form.label :effect_type, t('effects.effect_type'), class: "form-label small fw-semibold" %>
          <%= form.text_field :effect_type, class: "form-control form-control-sm", placeholder: "e.g. Defense, Healing..." %>
        </div>
        <div class="col-sm-6">
          <%= form.label :power_level, t('effects.power_level'), class: "form-label small fw-semibold" %>
          <%= form.number_field :power_level, class: "form-control form-control-sm", min: 0, max: 10, placeholder: "0–10" %>
        </div>
      </div>

      <div class="mb-0">
        <%= form.label :description, t('shared.description'), class: "form-label small fw-semibold" %>
        <%= form.text_area :description, class: "form-control form-control-sm", rows: 3, placeholder: "Describe the effect..." %>
      </div>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <%= form.submit @effect.persisted? ? t('shared.update') : t('shared.create'), class: "btn btn-sm btn-primary" %>
    <%= link_to t('shared.cancel'), effects_path, class: "btn btn-sm btn-outline-secondary" %>
  </div>
<% end %>
