<div class="container-fluid mt-4 px-3 px-lg-4">

  <%# Header %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0 fw-bold">
      <i class="bi bi-magic text-primary me-1"></i><%= t('effects.title') %>
      <span class="badge bg-primary rounded-pill ms-2 fs-6"><%= @pagy.count %></span>
    </h4>
    <a href="<%= new_effect_path %>" class="btn btn-sm btn-primary">
      <i class="bi bi-plus-lg me-1"></i><%= t('effects.new') %>
    </a>
  </div>

  <div class="row g-3">

    <%# ══════════════════════════════════ %>
    <%# LEFT: Master list with filters    %>
    <%# ══════════════════════════════════ %>
    <div class="col-lg-5 col-xl-4">

      <%# Search & Filters %>
      <% has_filters = params[:q].present? || params[:effect_type].present? || params[:power_level].present? %>
      <%= form_with url: effects_path, method: :get, local: true, id: "effects-filter-form" do %>
        <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
        <%= hidden_field_tag :dir, params[:dir] if params[:dir].present? %>
        <%= hidden_field_tag :per_page, params[:per_page] if params[:per_page].present? %>

        <div class="input-group input-group-sm mb-2">
          <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted"></i></span>
          <%= text_field_tag :q, params[:q],
            class: "form-control form-control-sm border-start-0 ps-0",
            placeholder: t('effects.search_placeholder'),
            id: "effects-search",
            autocomplete: "off" %>
          <% if has_filters %>
            <a href="<%= effects_path(sort: params[:sort], dir: params[:dir], per_page: params[:per_page]) %>" class="btn btn-outline-secondary btn-sm" title="<%= t('items.clear') %>">
              <i class="bi bi-x-lg"></i>
            </a>
          <% end %>
        </div>

        <div class="d-flex gap-2 mb-3">
          <%= select_tag :effect_type,
            options_for_select(@effect_types, params[:effect_type]),
            include_blank: t('effects.all_types'),
            class: "form-select form-select-sm",
            onchange: "this.form.requestSubmit()" %>
          <%= select_tag :power_level,
            options_for_select(@power_levels, params[:power_level]),
            include_blank: t('effects.all_powers'),
            class: "form-select form-select-sm",
            onchange: "this.form.requestSubmit()" %>
        </div>
      <% end %>

      <%# Sort %>
      <div class="d-flex align-items-center gap-3 mb-2">
        <span class="text-muted small fw-semibold text-uppercase" style="font-size: 0.6rem;">Sort:</span>
        <span style="font-size: 0.72rem;"><%= effects_sort_link(:name, t('shared.name')) %></span>
        <span style="font-size: 0.72rem;"><%= effects_sort_link(:effect_type, t('effects.effect_type')) %></span>
        <span style="font-size: 0.72rem;"><%= effects_sort_link(:power_level, t('effects.power_level')) %></span>
      </div>

      <%# Effect list %>
      <% if @effects.any? %>
        <div class="d-flex flex-column gap-1" id="effects-master-list">
          <% @effects.each_with_index do |effect, idx| %>
            <% color = effect_type_color(effect.effect_type) %>
            <% icon = effect_type_icon(effect.effect_type) %>
            <div class="effect-list-item p-2 rounded-2 border <%= 'active' if idx == 0 && !params[:selected].present? %>"
                 data-effect-id="<%= effect.id %>"
                 role="button"
                 onclick="selectEffect(this, <%= effect.id %>)"
                 style="cursor:pointer; border-left: 3px solid var(--bs-<%= color %>) !important; transition: background .1s;">
              <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-2 min-width-0 flex-grow-1">
                  <i class="bi bi-<%= icon %> text-<%= color %>" style="font-size: 0.85rem;"></i>
                  <div class="min-width-0">
                    <div class="fw-semibold small text-truncate"><%= effect.translated_name %></div>
                    <div class="d-flex align-items-center gap-1">
                      <span class="badge bg-<%= color %> bg-opacity-10 text-<%= color %>" style="font-size: 0.55rem;"><%= effect.effect_type %></span>
                      <% if effect.categories.any? %>
                        <span class="text-muted" style="font-size: 0.55rem;"><%= effect.categories.size %> cat.</span>
                      <% end %>
                    </div>
                  </div>
                </div>
                <span class="badge rounded-pill <%= power_level_badge_class(effect.power_level) %>" style="font-size: 0.7rem; min-width: 22px;"><%= effect.power_level %></span>
              </div>
            </div>
          <% end %>
        </div>

        <%# Pagination %>
        <nav class="mt-3 mb-2">
          <div class="d-flex align-items-center justify-content-between mb-1">
            <small class="text-muted" style="font-size: 0.7rem;">
              <%= t('effects.showing', from: @pagy.from, to: @pagy.to, count: @pagy.count) %>
            </small>
            <div class="d-flex align-items-center gap-1">
              <% [20, 50, 100].each do |n| %>
                <% active = (@pagy.limit == n) %>
                <a href="<%= effects_path(request.params.except("controller", "action").merge(per_page: n, page: nil)) %>"
                   class="btn btn-outline-secondary py-0 px-1 <%= 'active' if active %>"
                   style="font-size: 0.65rem;"><%= n %></a>
              <% end %>
            </div>
          </div>
          <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
        </nav>
      <% else %>
        <div class="text-center py-5">
          <i class="bi bi-inbox text-muted" style="font-size: 2.5rem;"></i>
          <p class="text-muted mt-2 small"><%= t('shared.no_records') %></p>
          <a href="<%= new_effect_path %>" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i><%= t('effects.new') %>
          </a>
        </div>
      <% end %>
    </div>

    <%# ══════════════════════════════════ %>
    <%# RIGHT: Detail panel               %>
    <%# ══════════════════════════════════ %>
    <div class="col-lg-7 col-xl-8">
      <div class="card border-0 shadow-sm sticky-lg-top" style="top: 72px;" id="effect-detail-panel">
        <div class="card-body" id="effect-detail-content">
          <% if @effects.any? %>
            <%# Initial detail: first effect %>
            <% first = @effects.first %>
            <% fc = effect_type_color(first.effect_type) %>
            <% fi = effect_type_icon(first.effect_type) %>
            <%= render partial: 'detail_inline', locals: { effect: first, color: fc, icon: fi } %>
          <% else %>
            <div class="text-center py-5 text-muted">
              <i class="bi bi-magic" style="font-size: 2rem;"></i>
              <p class="mt-2 small"><%= t('effects.select_to_view', default: 'Select an effect to see details') %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

  </div>
</div>

<style>
  .effect-list-item:hover { background: var(--bs-tertiary-bg); }
  .effect-list-item.active { background: var(--bs-primary-bg-subtle); border-color: var(--bs-primary) !important; }
</style>

<script>
  var _effectsLocalePrefix = "<%= I18n.locale == I18n.default_locale ? '' : "/#{I18n.locale}" %>";

  function selectEffect(el, id) {
    document.querySelectorAll('.effect-list-item').forEach(function(item) {
      item.classList.remove('active');
    });
    el.classList.add('active');

    var panel = document.getElementById('effect-detail-content');
    panel.innerHTML = '<div class="text-center py-5"><div class="spinner-border spinner-border-sm text-primary"></div></div>';

    fetch(_effectsLocalePrefix + '/effects/' + id + '/detail_panel', { headers: { 'Accept': 'text/html', 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.ok ? r.text() : Promise.reject(r); })
      .then(function(html) { panel.innerHTML = html; })
      .catch(function() { panel.innerHTML = '<div class="text-center py-3 text-danger small">Error loading detail.</div>'; });
  }

  // Debounced search
  function initEffectsSearch() {
    var searchInput = document.getElementById("effects-search");
    var form = document.getElementById("effects-filter-form");
    if (!searchInput || !form || searchInput.dataset.bound) return;
    searchInput.dataset.bound = "true";
    var timer;
    searchInput.addEventListener("keyup", function() {
      clearTimeout(timer);
      var v = searchInput.value.trim();
      timer = setTimeout(function() { if (v.length >= 3 || v.length === 0) form.requestSubmit(); }, 300);
    });
  }
  document.addEventListener("DOMContentLoaded", initEffectsSearch);
  document.addEventListener("turbo:load", initEffectsSearch);
</script>
