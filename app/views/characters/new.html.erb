<div class="container mt-4" style="max-width: 660px;">
  <div class="d-flex align-items-center gap-1 text-muted small mb-2">
    <%= link_to t("characters.title"), characters_path, class: "text-muted text-decoration-none" %>
    <i class="bi bi-chevron-right" style="font-size:0.7rem;"></i>
    <span><%= t("characters.new") %></span>
  </div>

  <h4 class="fw-bold mb-3">
    <i class="bi bi-person-plus text-primary me-2"></i><%= t("characters.new") %>
  </h4>

  <%= render "form", character: @character, character_classes: @character_classes,
             parties: @parties, form_url: characters_path %>
</div>
