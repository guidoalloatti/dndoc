<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <span class="current"><%= t('nav.effects') %></span>
  </span>
<% end %>

<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon bg-info bg-opacity-10">
      <i class="bi bi-stars text-info"></i>
    </div>
    <div>
      <h5><%= t('nav.effects') %></h5>
      <small><%= t('admin.effects.subtitle') %></small>
    </div>
  </div>
  <%= link_to new_admin_effect_path, class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-plus-lg me-1"></i><%= t('admin.effects.new') %>
  <% end %>
</div>

<%= form_with url: admin_effects_path, method: :get, local: true do |f| %>
  <div class="admin-filter-bar">
    <%= f.text_field :q, value: @q, placeholder: t('admin.search_placeholder'), class: "form-control", style: "max-width:200px;" %>
    <%= f.select :effect_type, options_for_select(@effect_types.map { |t| [t, t] }, @type_filter),
        { include_blank: t('admin.all_types') }, class: "form-select", style: "max-width:180px;" %>
    <%= f.submit t('shared.filter'), class: "btn btn-primary" %>
    <% if @q.present? || @type_filter.present? %>
      <%= link_to t('shared.clear'), admin_effects_path, class: "btn btn-outline-secondary" %>
    <% end %>
    <span class="admin-filter-count"><%= @pagy.count %> <%= t('shared.records') %></span>
  </div>
<% end %>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('shared.name') %> EN</th>
        <th class="d-none d-md-table-cell"><%= t('shared.name') %> ES</th>
        <th style="width:130px;"><%= t('effects.type') %></th>
        <th style="width:60px;">PWR</th>
        <th class="d-none d-lg-table-cell"><%= t('shared.description') %></th>
        <th class="admin-th-actions"><%= t('shared.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% @effects.each do |effect| %>
        <tr>
          <td class="fw-semibold"><%= effect.name %></td>
          <td class="text-muted small d-none d-md-table-cell"><%= effect.name_es.presence || "—" %></td>
          <td>
            <span class="badge bg-info bg-opacity-75 text-dark" style="font-size:0.62rem;"><%= effect.effect_type %></span>
          </td>
          <td>
            <span class="badge bg-primary rounded-pill" style="font-size:0.65rem; min-width:22px;"><%= effect.power_level %></span>
          </td>
          <td class="text-muted small d-none d-lg-table-cell" style="max-width:220px;">
            <span class="d-block text-truncate"><%= effect.description.presence || "—" %></span>
          </td>
          <td class="admin-td-actions">
            <div class="admin-act-group">
              <%= link_to edit_admin_effect_path(effect), class: "admin-act", title: t('shared.edit') do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= button_to admin_effect_path(effect), method: :delete,
                  class: "admin-act danger",
                  title: t('shared.delete'),
                  form: { data: { turbo_confirm: t('shared.confirm_delete') } } do %>
                <i class="bi bi-trash3"></i>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @effects.empty? %>
        <tr><td colspan="6" class="text-center text-muted py-4 small"><i class="bi bi-inbox me-1 opacity-50"></i><%= t('shared.no_records') %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center mt-3"><%== pagy_bootstrap_nav(@pagy) %></div>
<% end %>
