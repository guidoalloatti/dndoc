<% rarity_colors = { 'Common' => 'secondary', 'Uncommon' => 'success', 'Rare' => 'info', 'Very Rare' => 'primary', 'Legendary' => 'warning', 'Ancestral' => 'danger' } %>

<div class="container-fluid py-3 px-md-4" style="max-width: 1400px;">

  <%# ── Compact Header ── %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-2">
      <div class="rounded-2 bg-danger bg-opacity-10 p-2 d-flex">
        <i class="bi bi-shield-lock-fill text-danger fs-5"></i>
      </div>
      <div>
        <h5 class="fw-bold mb-0 lh-1"><%= t('admin.dashboard') %></h5>
        <small class="text-body-secondary"><%= t('admin.dashboard_subtitle') %></small>
      </div>
    </div>
    <%= link_to admin_users_path, class: "btn btn-sm btn-primary" do %>
      <i class="bi bi-people me-1"></i><%= t('admin.manage_users') %>
    <% end %>
  </div>

  <%# ── Inline Stats Bar ── %>
  <div class="rounded-3 p-2 mb-3" style="background: var(--bs-tertiary-bg);">
    <div class="d-flex flex-wrap justify-content-center gap-3">
      <% [
        { icon: "bi-people-fill", color: "primary", value: @stats[:total_users], label: t('admin.total_users') },
        { icon: "bi-shield-fill", color: "danger", value: @stats[:admin_users], label: t('admin.admin_users') },
        { icon: "bi-box-seam-fill", color: "success", value: @stats[:total_items], label: t('admin.total_items') },
        { icon: "bi-magic", color: "info", value: @stats[:total_effects], label: t('admin.total_effects') },
        { icon: "bi-grid-3x3-gap-fill", color: "warning", value: @stats[:total_categories], label: t('admin.total_categories') },
        { icon: "bi-gem", color: "secondary", value: @stats[:total_rarities], label: t('admin.total_rarities') },
        { icon: "bi-hammer", color: "dark", value: @stats[:total_weapons], label: t('admin.total_weapons') },
      ].each do |stat| %>
        <div class="d-flex align-items-center gap-2 px-2">
          <i class="bi <%= stat[:icon] %> text-<%= stat[:color] %>"></i>
          <span class="fw-bold text-<%= stat[:color] %>"><%= stat[:value] %></span>
          <span class="text-body-secondary small"><%= stat[:label] %></span>
        </div>
      <% end %>
    </div>
  </div>

  <div class="row g-3">
    <%# ── Left Column: Top Creators + Rarity Distribution ── %>
    <div class="col-lg-4">
      <%# Top Creators %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
          <h6 class="fw-bold small text-uppercase text-muted mb-2">
            <i class="bi bi-trophy-fill text-warning me-1"></i><%= t('admin.top_creators') %>
          </h6>
          <% @top_creators.each_with_index do |user, idx| %>
            <div class="d-flex align-items-center gap-2 py-1 <%= idx < @top_creators.size - 1 ? 'border-bottom' : '' %>">
              <span class="fw-bold text-<%= idx == 0 ? 'warning' : 'muted' %>" style="width: 16px; font-size: 0.75rem;"><%= idx + 1 %></span>
              <% if user.has_avatar? %>
                <% if user.avatar.attached? %>
                  <%= image_tag user.avatar, class: "rounded-circle object-fit-cover", width: 24, height: 24 %>
                <% else %>
                  <img src="<%= user.avatar_url %>" class="rounded-circle object-fit-cover" width="24" height="24">
                <% end %>
              <% else %>
                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 24px; height: 24px;">
                  <span style="font-size: 0.6rem;" class="fw-bold text-primary"><%= user.initials %></span>
                </div>
              <% end %>
              <div class="flex-grow-1 min-width-0">
                <div class="fw-semibold small text-truncate"><%= user.full_name %></div>
              </div>
              <span class="badge bg-primary bg-opacity-10 text-primary" style="font-size: 0.65rem;"><%= user.items_count %></span>
            </div>
          <% end %>
          <% if @top_creators.empty? %>
            <p class="text-muted text-center small my-2 mb-0"><%= t('shared.no_records') %></p>
          <% end %>
        </div>
      </div>

      <%# Rarity Distribution %>
      <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
          <h6 class="fw-bold small text-uppercase text-muted mb-2">
            <i class="bi bi-gem text-info me-1"></i><%= t('admin.items_by_rarity') %>
          </h6>
          <% total_items = @items_by_rarity.sum(&:items_count).to_f %>
          <% @items_by_rarity.each do |r| %>
            <div class="d-flex align-items-center gap-2 mb-2">
              <span class="badge bg-<%= rarity_colors[r.name] || 'secondary' %> <%= r.name == 'Legendary' ? 'text-dark' : '' %>" style="width: 70px; font-size: 0.6rem;"><%= r.name %></span>
              <div class="flex-grow-1">
                <div class="progress" style="height: 4px;">
                  <div class="progress-bar bg-<%= rarity_colors[r.name] || 'secondary' %>" style="width: <%= total_items > 0 ? (r.items_count / total_items * 100).round(1) : 0 %>%;"></div>
                </div>
              </div>
              <span class="text-muted fw-semibold" style="font-size: 0.7rem; width: 24px; text-align: right;"><%= r.items_count %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Right Column: Activity Feed ── %>
    <div class="col-lg-8">
      <%# Recent Users %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="fw-bold small text-uppercase text-muted mb-0">
              <i class="bi bi-person-plus-fill text-success me-1"></i><%= t('admin.recent_users') %>
            </h6>
            <%= link_to t('admin.view_all_users'), admin_users_path, class: "small text-primary text-decoration-none fw-semibold" %>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <% @recent_users.each do |user| %>
              <%= link_to admin_user_path(user), class: "text-decoration-none" do %>
                <div class="d-flex align-items-center gap-2 rounded-pill px-3 py-1 border" style="background: var(--bs-tertiary-bg); transition: all 0.15s;">
                  <% if user.has_avatar? %>
                    <% if user.avatar.attached? %>
                      <%= image_tag user.avatar, class: "rounded-circle object-fit-cover", width: 22, height: 22 %>
                    <% else %>
                      <img src="<%= user.avatar_url %>" class="rounded-circle object-fit-cover" width="22" height="22">
                    <% end %>
                  <% else %>
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 22px; height: 22px;">
                      <span style="font-size: 0.55rem;" class="fw-bold text-primary"><%= user.initials %></span>
                    </div>
                  <% end %>
                  <span class="small fw-semibold"><%= user.full_name %></span>
                  <% if user.admin? %>
                    <i class="bi bi-shield-fill text-danger" style="font-size: 0.6rem;"></i>
                  <% end %>
                  <% if user.google_linked? %>
                    <i class="bi bi-google text-primary" style="font-size: 0.55rem;"></i>
                  <% end %>
                  <span class="text-muted" style="font-size: 0.6rem;"><%= user.created_at.strftime("%b %d") %></span>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>

      <%# Recent Items %>
      <div class="card border-0 shadow-sm">
        <div class="card-body p-3">
          <h6 class="fw-bold small text-uppercase text-muted mb-2">
            <i class="bi bi-box-seam-fill text-primary me-1"></i><%= t('admin.recent_items') %>
          </h6>
          <% if @recent_items.any? %>
            <% @recent_items.each_with_index do |item, idx| %>
              <div class="d-flex align-items-center gap-2 py-2 <%= idx < @recent_items.size - 1 ? 'border-bottom' : '' %>">
                <span class="badge bg-<%= rarity_colors[item.rarity&.name] || 'secondary' %> <%= item.rarity&.name == 'Legendary' ? 'text-dark' : '' %>" style="font-size: 0.55rem; width: 60px;"><%= item.rarity&.name %></span>
                <div class="flex-grow-1 min-width-0">
                  <%= link_to item.name, item_path(item), class: "fw-semibold small text-decoration-none text-truncate d-block" %>
                </div>
                <span class="text-muted small d-none d-md-inline"><%= item.category&.name %></span>
                <span class="badge bg-primary rounded-pill" style="font-size: 0.6rem;"><%= item.power %></span>
                <div class="d-flex align-items-center gap-1 d-none d-md-flex">
                  <% if item.user %>
                    <% if item.user.has_avatar? %>
                      <% if item.user.avatar.attached? %>
                        <%= image_tag item.user.avatar, class: "rounded-circle object-fit-cover", width: 18, height: 18 %>
                      <% else %>
                        <img src="<%= item.user.avatar_url %>" class="rounded-circle object-fit-cover" width="18" height="18">
                      <% end %>
                    <% else %>
                      <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 18px; height: 18px;">
                        <span style="font-size: 0.5rem;" class="fw-bold text-primary"><%= item.user.initials %></span>
                      </div>
                    <% end %>
                  <% end %>
                </div>
                <span class="text-muted" style="font-size: 0.6rem;"><%= item.created_at.strftime("%b %d") %></span>
              </div>
            <% end %>
          <% else %>
            <p class="text-muted text-center small my-2 mb-0"><%= t('shared.no_records') %></p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
