<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <span class="current"><%= t('character_classes.title') %></span>
  </span>
<% end %>

<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon bg-primary bg-opacity-10">
      <i class="bi bi-shield-shaded text-primary"></i>
    </div>
    <div>
      <h5><%= t('character_classes.title') %></h5>
      <small><%= t('admin.character_classes.subtitle') %></small>
    </div>
  </div>
  <%= link_to new_admin_character_class_path, class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-plus-lg me-1"></i><%= t('character_classes.new') %>
  <% end %>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('shared.name') %></th>
        <th class="d-none d-lg-table-cell"><%= t('shared.description') %></th>
        <th style="width:90px;" class="text-center"><%= t('character_classes.is_magic_user') %></th>
        <th style="width:90px;" class="text-center"><%= t('character_classes.affinities') %></th>
        <th class="admin-th-actions"><%= t('shared.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% @character_classes.each do |cc| %>
        <tr>
          <td class="fw-semibold"><%= cc.name %></td>
          <td class="text-muted small d-none d-lg-table-cell" style="max-width:280px;">
            <span class="d-block text-truncate"><%= cc.description.presence || "—" %></span>
          </td>
          <td class="text-center">
            <% if cc.is_magic_user %>
              <i class="bi bi-stars text-primary"></i>
            <% else %>
              <i class="bi bi-shield text-secondary opacity-50"></i>
            <% end %>
          </td>
          <td class="text-center">
            <span class="badge bg-secondary bg-opacity-75 rounded-pill" style="font-size:0.65rem;"><%= cc.class_category_affinities.count %></span>
          </td>
          <td class="admin-td-actions">
            <div class="admin-act-group">
              <%= link_to admin_character_class_path(cc), class: "admin-act", title: t('shared.show') do %>
                <i class="bi bi-eye"></i>
              <% end %>
              <%= link_to edit_admin_character_class_path(cc), class: "admin-act", title: t('shared.edit') do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= button_to admin_character_class_path(cc), method: :delete,
                  class: "admin-act danger",
                  title: t('shared.delete'),
                  form: { data: { turbo_confirm: t('shared.confirm_delete') } } do %>
                <i class="bi bi-trash3"></i>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @character_classes.empty? %>
        <tr><td colspan="5" class="text-center text-muted py-4 small"><i class="bi bi-inbox me-1 opacity-50"></i><%= t('shared.no_records') %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center mt-3"><%== pagy_bootstrap_nav(@pagy) %></div>
<% end %>
