<div class="container mt-4">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0 fw-bold">
      <i class="bi bi-shield-shaded text-primary me-1"></i> <%= t('character_classes.title') %>
    </h4>
    <div class="d-flex gap-2">
      <%= link_to admin_root_path, class: "btn btn-sm btn-outline-secondary" do %>
        <i class="bi bi-arrow-left me-1"></i><%= t('admin.back_to_dashboard') %>
      <% end %>
      <%= link_to new_admin_character_class_path, class: "btn btn-sm btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i><%= t('character_classes.new') %>
      <% end %>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th class="small"><%= t('shared.name') %></th>
            <th class="small"><%= t('shared.description') %></th>
            <th class="small text-center"><%= t('character_classes.is_magic_user') %></th>
            <th class="small text-center"><%= t('character_classes.affinities') %></th>
            <th class="small text-end"><%= t('shared.actions') %></th>
          </tr>
        </thead>
        <tbody>
          <% @character_classes.each do |cc| %>
            <tr>
              <td class="fw-semibold"><%= cc.name %></td>
              <td class="text-muted small"><%= cc.description %></td>
              <td class="text-center">
                <% if cc.is_magic_user %>
                  <i class="bi bi-stars text-primary"></i>
                <% else %>
                  <i class="bi bi-shield text-secondary"></i>
                <% end %>
              </td>
              <td class="text-center">
                <span class="badge bg-secondary"><%= cc.class_category_affinities.count %></span>
              </td>
              <td class="text-end">
                <%= link_to admin_character_class_path(cc), class: "btn btn-sm btn-outline-primary me-1" do %>
                  <i class="bi bi-eye"></i>
                <% end %>
                <%= link_to edit_admin_character_class_path(cc), class: "btn btn-sm btn-outline-secondary me-1" do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <%= button_to admin_character_class_path(cc), method: :delete, class: "btn btn-sm btn-outline-danger", data: { turbo_confirm: t('shared.confirm_delete') } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-3">
    <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
  </div>
</div>
