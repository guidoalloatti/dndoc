<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <span class="current"><%= t('nav.characters') %></span>
  </span>
<% end %>

<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon" style="background:rgba(111,66,193,0.1);">
      <i class="bi bi-person-badge" style="color:#6f42c1;"></i>
    </div>
    <div>
      <h5><%= t('nav.characters') %></h5>
      <small><%= t('admin.characters.subtitle') %></small>
    </div>
  </div>
</div>

<%= form_with url: admin_characters_path, method: :get, local: true do |f| %>
  <div class="admin-filter-bar">
    <%= f.text_field :q, value: @q, placeholder: t('admin.search_placeholder'), class: "form-control", style: "max-width:260px;" %>
    <%= f.submit t('shared.filter'), class: "btn btn-primary" %>
    <% if @q.present? %>
      <%= link_to t('shared.clear'), admin_characters_path, class: "btn btn-outline-secondary" %>
    <% end %>
    <span class="admin-filter-count"><%= @pagy.count %> <%= t('shared.records') %></span>
  </div>
<% end %>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('shared.name') %></th>
        <th><%= t('characters.race') %></th>
        <th><%= t('characters.class') %></th>
        <th style="width:70px;"><%= t('characters.level') %></th>
        <th><%= t('nav.parties') %></th>
        <th style="width:60px;"><%= t('nav.items') %></th>
        <th class="d-none d-lg-table-cell" style="width:110px;"><%= t('shared.created_at') %></th>
        <th class="admin-th-actions"><%= t('shared.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% @characters.each do |char| %>
        <tr>
          <td class="fw-semibold"><%= char.name %></td>
          <td class="text-muted small"><%= char.race.presence || "—" %></td>
          <td class="text-muted small"><%= char.character_class&.name || "—" %></td>
          <td>
            <span class="badge bg-secondary bg-opacity-75 rounded-pill" style="font-size:0.65rem;">Lv <%= char.level %></span>
          </td>
          <td class="text-muted small"><%= char.party&.name || "—" %></td>
          <td>
            <span class="badge bg-success bg-opacity-75 rounded-pill" style="font-size:0.65rem;"><%= char.items.size %></span>
          </td>
          <td class="text-muted d-none d-lg-table-cell" style="font-size:0.72rem;"><%= char.created_at.strftime("%b %d, %Y") %></td>
          <td class="admin-td-actions">
            <div class="admin-act-group">
              <%= button_to admin_character_path(char), method: :delete,
                  class: "admin-act danger",
                  title: t('shared.delete'),
                  form: { data: { turbo_confirm: t('shared.confirm_delete') } } do %>
                <i class="bi bi-trash3"></i>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @characters.empty? %>
        <tr><td colspan="8" class="text-center text-muted py-4 small"><i class="bi bi-inbox me-1 opacity-50"></i><%= t('shared.no_records') %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center mt-3"><%== pagy_bootstrap_nav(@pagy) %></div>
<% end %>
