<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <a href="<%= admin_lore_entries_path %>"><%= t('nav.lore') %></a>
    <span class="sep">/</span>
    <span class="current"><%= t('admin.lore_entries.new') %></span>
  </span>
<% end %>
<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon bg-secondary bg-opacity-10"><i class="bi bi-book-fill text-secondary"></i></div>
    <div><h5><%= t('admin.lore_entries.new') %></h5></div>
  </div>
</div>
<%= render 'form', lore_entry: @lore_entry %>
