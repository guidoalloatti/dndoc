    <div class="admin-title-icon bg-secondary bg-opacity-10"><i class="bi bi-hammer text-secondary"></i></div>
    <div><h5><%= t('admin.weapons.new') %></h5></div>
  </div>
</div>
<%= render 'form', weapon: @weapon %>
