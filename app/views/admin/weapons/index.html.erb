<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <span class="current"><%= t('nav.weapons') %></span>
  </span>
<% end %>

<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon bg-secondary bg-opacity-10">
      <i class="bi bi-hammer text-secondary"></i>
    </div>
    <div>
      <h5><%= t('nav.weapons') %></h5>
      <small><%= t('admin.weapons.subtitle') %></small>
    </div>
  </div>
  <%= link_to new_admin_weapon_path, class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-plus-lg me-1"></i><%= t('admin.weapons.new') %>
  <% end %>
</div>

<%= form_with url: admin_weapons_path, method: :get, local: true do |f| %>
  <div class="admin-filter-bar">
    <%= f.text_field :q, value: @q, placeholder: t('admin.search_placeholder'), class: "form-control", style: "max-width:260px;" %>
    <%= f.submit t('shared.filter'), class: "btn btn-primary" %>
    <% if @q.present? %>
      <%= link_to t('shared.clear'), admin_weapons_path, class: "btn btn-outline-secondary" %>
    <% end %>
    <span class="admin-filter-count"><%= @pagy.count %> <%= t('shared.records') %></span>
  </div>
<% end %>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('shared.name') %></th>
        <th style="width:130px;"><%= t('weapons.damage') %></th>
        <th style="width:90px;"><%= t('weapons.cost') %></th>
        <th style="width:90px;"><%= t('weapons.weight') %></th>
        <th class="d-none d-lg-table-cell"><%= t('weapons.properties') %></th>
        <th class="admin-th-actions"><%= t('shared.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% @weapons.each do |weapon| %>
        <tr>
          <td class="fw-semibold"><%= weapon.name %></td>
          <td>
            <span class="badge bg-danger bg-opacity-75" style="font-size:0.62rem;"><%= weapon.damage %></span>
          </td>
          <td class="text-muted small"><%= weapon.cost %> gp</td>
          <td class="text-muted small"><%= weapon.weight %> lbs</td>
          <td class="text-muted small d-none d-lg-table-cell" style="max-width:200px;">
            <span class="d-block text-truncate"><%= weapon.properties.presence || "—" %></span>
          </td>
          <td class="admin-td-actions">
            <div class="admin-act-group">
              <%= link_to edit_admin_weapon_path(weapon), class: "admin-act", title: t('shared.edit') do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= button_to admin_weapon_path(weapon), method: :delete,
                  class: "admin-act danger",
                  title: t('shared.delete'),
                  form: { data: { turbo_confirm: t('shared.confirm_delete') } } do %>
                <i class="bi bi-trash3"></i>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @weapons.empty? %>
        <tr><td colspan="6" class="text-center text-muted py-4 small"><i class="bi bi-inbox me-1 opacity-50"></i><%= t('shared.no_records') %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center mt-3"><%== pagy_bootstrap_nav(@pagy) %></div>
<% end %>
