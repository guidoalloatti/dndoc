<div class="admin-form-card">
  <%= form_with model: [:admin, weapon], local: true do |f| %>
    <% if weapon.errors.any? %>
      <div class="alert alert-danger mb-3 py-2" style="font-size:0.8rem;">
        <% weapon.errors.full_messages.each do |msg| %>
          <div><i class="bi bi-exclamation-circle me-1"></i><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :name, t('shared.name'), class: "form-label" %>
      <%= f.text_field :name, class: "form-control #{'is-invalid' if weapon.errors[:name].any?}" %>
    </div>

    <div class="mb-3">
      <%= f.label :damage, t('weapons.damage'), class: "form-label" %>
      <%= f.text_field :damage, placeholder: "e.g. 1d8 slashing", class: "form-control #{'is-invalid' if weapon.errors[:damage].any?}" %>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-6">
        <%= f.label :cost, t('weapons.cost') + " (gp)", class: "form-label" %>
        <%= f.number_field :cost, step: 0.01, min: 0, class: "form-control" %>
      </div>
      <div class="col-6">
        <%= f.label :weight, t('weapons.weight') + " (lbs)", class: "form-label" %>
        <%= f.number_field :weight, step: 0.1, min: 0, class: "form-control" %>
      </div>
    </div>

    <div class="mb-4">
      <%= f.label :properties, t('weapons.properties'), class: "form-label" %>
      <%= f.text_area :properties, rows: 2, placeholder: "e.g. Finesse, Light, Thrown (20/60)", class: "form-control" %>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit t('shared.save'), class: "btn btn-primary" %>
      <%= link_to t('shared.cancel'), admin_weapons_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
