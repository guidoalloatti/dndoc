<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <span class="current"><%= t('admin.users_title') %></span>
  </span>
<% end %>

<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon bg-primary bg-opacity-10">
      <i class="bi bi-people text-primary"></i>
    </div>
    <div>
      <h5><%= t('admin.users_title') %></h5>
      <small><%= t('admin.users_subtitle') %></small>
    </div>
  </div>
</div>

<%= form_tag admin_users_path, method: :get, class: "" do %>
  <div class="admin-filter-bar">
    <div class="input-group" style="max-width:260px;">
      <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search text-muted" style="font-size:0.75rem;"></i></span>
      <%= text_field_tag :search, params[:search], class: "form-control border-start-0", placeholder: t('admin.search_users') %>
    </div>
    <% [
      ["", t('admin.all_roles'), "secondary"],
      ["admin", "Admin", "danger"],
      ["user", "User", "primary"]
    ].each do |value, label, color| %>
      <button type="submit" name="role" value="<%= value %>"
              class="btn btn-sm <%= params[:role] == value || (value == '' && params[:role].blank?) ? "btn-#{color}" : "btn-outline-#{color}" %>">
        <%= label %>
      </button>
    <% end %>
    <% if params[:search].present? || params[:role].present? %>
      <%= link_to admin_users_path, class: "btn btn-outline-secondary" do %>
        <i class="bi bi-x-lg"></i>
      <% end %>
    <% end %>
    <span class="admin-filter-count"><%= @pagy.count %> <%= t('shared.records') %></span>
  </div>
<% end %>

<div class="row g-2 mt-1">
  <% @users.each do |user| %>
    <div class="col-md-6 col-xl-4">
      <div class="card border admin-user-card h-100">
        <div class="card-body p-3">
          <div class="d-flex align-items-start gap-3">
            <%# Avatar %>
            <% if user.has_avatar? %>
              <% if user.avatar.attached? %>
                <%= image_tag user.avatar, class: "rounded-circle object-fit-cover flex-shrink-0", width: 44, height: 44 %>
              <% else %>
                <img src="<%= user.avatar_url %>" class="rounded-circle object-fit-cover flex-shrink-0" width="44" height="44">
              <% end %>
            <% else %>
              <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width:44px;height:44px;">
                <span class="fw-bold text-primary"><%= user.initials %></span>
              </div>
            <% end %>

            <%# Info %>
            <div class="flex-grow-1" style="min-width:0;">
              <div class="d-flex align-items-center gap-1 mb-1">
                <%= link_to user.full_name, admin_user_path(user), class: "fw-semibold small text-decoration-none text-truncate" %>
                <% if user == current_user %>
                  <span class="badge bg-info-subtle text-info rounded-pill" style="font-size:0.55rem;padding:2px 6px;"><%= t('admin.you') %></span>
                <% end %>
              </div>
              <div class="text-muted text-truncate" style="font-size:0.7rem;"><%= user.email %></div>
              <div class="d-flex align-items-center gap-2 mt-2 flex-wrap">
                <% if user.admin? %>
                  <span class="badge bg-danger bg-opacity-10 text-danger" style="font-size:0.6rem;">
                    <i class="bi bi-shield-fill me-1"></i>Admin
                  </span>
                <% else %>
                  <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size:0.6rem;">User</span>
                <% end %>
                <% if user.google_linked? %>
                  <span class="badge bg-primary bg-opacity-10 text-primary" style="font-size:0.6rem;">
                    <i class="bi bi-google me-1"></i>Google
                  </span>
                <% end %>
                <span class="text-muted" style="font-size:0.6rem;">
                  <i class="bi bi-box-seam me-1"></i><%= user.items_count %>
                </span>
                <span class="text-muted ms-auto" style="font-size:0.6rem;"><%= user.created_at.strftime("%b %d, '%y") %></span>
              </div>
            </div>

            <%# Actions %>
            <div class="d-flex flex-column gap-1 flex-shrink-0">
              <%= link_to admin_user_path(user), class: "admin-act", title: t('shared.show') do %>
                <i class="bi bi-eye"></i>
              <% end %>
              <% unless user == current_user %>
                <%= button_to toggle_admin_admin_user_path(user), method: :patch,
                      class: "admin-act #{user.admin? ? 'danger' : ''}",
                      title: user.admin? ? t('admin.revoke_admin') : t('admin.make_admin'),
                      form: { data: { turbo_confirm: t('admin.confirm_role_change', name: user.full_name, role: user.admin? ? 'User' : 'Admin') } } do %>
                  <i class="bi bi-<%= user.admin? ? 'shield-x' : 'shield-plus' %>"></i>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
  <% if @users.empty? %>
    <div class="col-12 text-center py-5">
      <i class="bi bi-people text-muted" style="font-size:2.5rem;opacity:0.3;"></i>
      <p class="text-muted mt-2 small"><%= t('shared.no_records') %></p>
    </div>
  <% end %>
</div>

<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center mt-3"><%== pagy_bootstrap_nav(@pagy) %></div>
<% end %>
