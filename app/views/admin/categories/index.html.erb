<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <span class="current"><%= t('nav.categories') %></span>
  </span>
<% end %>

<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon bg-warning bg-opacity-10">
      <i class="bi bi-grid-3x3-gap text-warning"></i>
    </div>
    <div>
      <h5><%= t('nav.categories') %></h5>
      <small><%= t('admin.categories.subtitle') %></small>
    </div>
  </div>
  <%= link_to new_admin_category_path, class: "btn btn-primary btn-sm" do %>
    <i class="bi bi-plus-lg me-1"></i><%= t('admin.categories.new') %>
  <% end %>
</div>

<%= form_with url: admin_categories_path, method: :get, local: true do |f| %>
  <div class="admin-filter-bar">
    <%= f.text_field :q, value: @q, placeholder: t('admin.search_placeholder'), class: "form-control", style: "max-width:260px;" %>
    <%= f.submit t('shared.filter'), class: "btn btn-primary" %>
    <% if @q.present? %>
      <%= link_to t('shared.clear'), admin_categories_path, class: "btn btn-outline-secondary" %>
    <% end %>
    <span class="admin-filter-count"><%= @pagy.count %> <%= t('shared.records') %></span>
  </div>
<% end %>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th><%= t('shared.name') %></th>
        <th class="d-none d-md-table-cell"><%= t('shared.description') %></th>
        <th style="width:130px;"><%= t('categories.weight_range') %></th>
        <th style="width:60px;"><%= t('nav.items') %></th>
        <th class="admin-th-actions"><%= t('shared.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% @categories.each do |cat| %>
        <tr>
          <td class="fw-semibold"><%= cat.name %></td>
          <td class="text-muted small d-none d-md-table-cell" style="max-width:260px;">
            <span class="d-block text-truncate"><%= cat.description.presence || "—" %></span>
          </td>
          <td class="text-muted small">
            <% if cat.min_weight || cat.max_weight %>
              <%= cat.min_weight %>–<%= cat.max_weight %> lbs
            <% else %>—<% end %>
          </td>
          <td>
            <span class="badge bg-secondary bg-opacity-75 rounded-pill" style="font-size:0.65rem;"><%= cat.items.size %></span>
          </td>
          <td class="admin-td-actions">
            <div class="admin-act-group">
              <%= link_to edit_admin_category_path(cat), class: "admin-act", title: t('shared.edit') do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= button_to admin_category_path(cat), method: :delete,
                  class: "admin-act danger",
                  title: t('shared.delete'),
                  form: { data: { turbo_confirm: t('shared.confirm_delete') } } do %>
                <i class="bi bi-trash3"></i>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @categories.empty? %>
        <tr><td colspan="5" class="text-center text-muted py-4 small"><i class="bi bi-inbox me-1 opacity-50"></i><%= t('shared.no_records') %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center mt-3"><%== pagy_bootstrap_nav(@pagy) %></div>
<% end %>
