<div class="admin-form-card">
  <%= form_with model: [:admin, category], local: true do |f| %>
    <% if category.errors.any? %>
      <div class="alert alert-danger mb-3 py-2" style="font-size:0.8rem;">
        <% category.errors.full_messages.each do |msg| %>
          <div><i class="bi bi-exclamation-circle me-1"></i><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :name, t('shared.name'), class: "form-label" %>
      <%= f.text_field :name, class: "form-control #{'is-invalid' if category.errors[:name].any?}" %>
    </div>

    <div class="mb-3">
      <%= f.label :description, t('shared.description'), class: "form-label" %>
      <%= f.text_area :description, rows: 3, class: "form-control" %>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-6">
        <%= f.label :min_weight, t('categories.min_weight'), class: "form-label" %>
        <%= f.number_field :min_weight, step: 0.1, min: 0, class: "form-control" %>
      </div>
      <div class="col-6">
        <%= f.label :max_weight, t('categories.max_weight'), class: "form-label" %>
        <%= f.number_field :max_weight, step: 0.1, min: 0, class: "form-control" %>
      </div>
    </div>

    <div class="mb-4">
      <label class="form-label"><i class="bi bi-image me-1"></i><%= t('categories.image') %></label>
      <% if category.image.attached? %>
        <div class="mb-2">
          <%= image_tag category.image, class: "rounded", style: "max-height:120px; max-width:100%; object-fit:cover; display:block;" %>
        </div>
      <% end %>
      <%= f.file_field :image, accept: "image/*", class: "form-control form-control-sm" %>
      <div class="form-text"><%= t('categories.image_hint') %></div>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit t('shared.save'), class: "btn btn-primary" %>
      <%= link_to t('shared.cancel'), admin_categories_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
