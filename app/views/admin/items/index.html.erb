<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <span class="current"><%= t('nav.items') %></span>
  </span>
<% end %>

<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon bg-success bg-opacity-10">
      <i class="bi bi-box-seam-fill text-success"></i>
    </div>
    <div>
      <h5><%= t('nav.items') %></h5>
      <small><%= t('admin.items.subtitle') %></small>
    </div>
  </div>
</div>

<%= form_with url: admin_items_path, method: :get, local: true do |f| %>
  <div class="admin-filter-bar">
    <%= f.text_field :q, value: @q, placeholder: t('admin.search_placeholder'), class: "form-control", style: "max-width:200px;" %>
    <%= f.select :category_id, options_from_collection_for_select(@categories, :id, :name, @category_filter),
        { include_blank: t('items.all_categories') }, class: "form-select", style: "max-width:170px;" %>
    <%= f.select :rarity_id, options_from_collection_for_select(@rarities, :id, :name, @rarity_filter),
        { include_blank: t('items.all_rarities') }, class: "form-select", style: "max-width:150px;" %>
    <%= f.submit t('shared.filter'), class: "btn btn-primary" %>
    <% if @q.present? || @category_filter.present? || @rarity_filter.present? %>
      <%= link_to t('shared.clear'), admin_items_path, class: "btn btn-outline-secondary" %>
    <% end %>
    <span class="admin-filter-count"><%= @pagy.count %> <%= t('shared.records') %></span>
  </div>
<% end %>

<% rarity_colors = { 'Common' => 'secondary', 'Uncommon' => 'success', 'Rare' => 'info', 'Very Rare' => 'primary', 'Legendary' => 'warning', 'Ancestral' => 'danger' } %>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th style="width:40px;">#</th>
        <th><%= t('items.name') %></th>
        <th><%= t('items.rarity') %></th>
        <th><%= t('items.category') %></th>
        <th style="width:56px;"><%= t('items.power') %></th>
        <th class="d-none d-md-table-cell" style="width:52px;">FX</th>
        <th class="d-none d-lg-table-cell"><%= t('admin.owner') %></th>
        <th class="d-none d-lg-table-cell" style="width:100px;"><%= t('shared.created_at') %></th>
        <th class="admin-th-actions"><%= t('shared.actions') %></th>
      </tr>
    </thead>
    <tbody>
      <% @items.each do |item| %>
        <tr>
          <td class="text-muted" style="font-size:0.7rem;"><%= item.id %></td>
          <td>
            <span class="fw-semibold"><%= item.name %></span>
            <% if item.requires_attunement %>
              <i class="bi bi-link-45deg text-warning ms-1" style="font-size:0.68rem;" title="Attunement required"></i>
            <% end %>
          </td>
          <td>
            <span class="badge bg-<%= rarity_colors[item.rarity&.name] || 'secondary' %>" style="font-size:0.6rem;">
              <%= item.rarity&.name %>
            </span>
          </td>
          <td class="text-muted small"><%= item.category&.name %></td>
          <td>
            <span class="badge bg-primary rounded-pill" style="font-size:0.65rem; min-width:22px;"><%= item.power %></span>
          </td>
          <td class="text-muted small d-none d-md-table-cell"><%= item.effects.size %></td>
          <td class="text-muted small d-none d-lg-table-cell"><%= item.user&.full_name || "—" %></td>
          <td class="text-muted d-none d-lg-table-cell" style="font-size:0.72rem;"><%= item.created_at.strftime("%b %d, %Y") %></td>
          <td class="admin-td-actions">
            <div class="admin-act-group">
              <%= link_to admin_item_path(item), class: "admin-act", title: t('shared.show') do %>
                <i class="bi bi-eye"></i>
              <% end %>
              <%= link_to item_path(item), class: "admin-act", title: t('admin.view_in_app'), target: "_blank", rel: "noopener" do %>
                <i class="bi bi-box-arrow-up-right"></i>
              <% end %>
              <%= button_to admin_item_path(item), method: :delete,
                  class: "admin-act danger",
                  title: t('shared.delete'),
                  form: { data: { turbo_confirm: t('shared.confirm_delete') } } do %>
                <i class="bi bi-trash3"></i>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @items.empty? %>
        <tr>
          <td colspan="9" class="text-center text-muted py-4 small">
            <i class="bi bi-inbox me-1 opacity-50"></i><%= t('shared.no_records') %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy.pages > 1 %>
  <div class="d-flex justify-content-center mt-3"><%== pagy_bootstrap_nav(@pagy) %></div>
<% end %>
