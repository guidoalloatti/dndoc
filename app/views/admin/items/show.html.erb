<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <a href="<%= admin_items_path %>"><%= t('nav.items') %></a>
    <span class="sep">/</span>
    <span class="current"><%= @item.name %></span>
  </span>
<% end %>

<% rarity_colors = { 'Common' => 'secondary', 'Uncommon' => 'success', 'Rare' => 'info', 'Very Rare' => 'primary', 'Legendary' => 'warning', 'Ancestral' => 'danger' } %>

<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon bg-success bg-opacity-10">
      <i class="bi bi-box-seam-fill text-success"></i>
    </div>
    <div>
      <h5><%= @item.name %></h5>
      <small><%= t('nav.items') %> #<%= @item.id %></small>
    </div>
  </div>
  <div class="d-flex gap-2">
    <%= link_to item_path(@item), class: "btn btn-sm btn-outline-secondary", target: "_blank" do %>
      <i class="bi bi-box-arrow-up-right me-1"></i><%= t('admin.view_in_app') %>
    <% end %>
    <%= button_to admin_item_path(@item), method: :delete,
        class: "btn btn-sm btn-outline-danger",
        form: { data: { turbo_confirm: t('shared.confirm_delete') } } do %>
      <i class="bi bi-trash3 me-1"></i><%= t('shared.delete') %>
    <% end %>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-7">
    <div class="admin-form-card" style="max-width:100%;">
      <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="badge bg-<%= rarity_colors[@item.rarity&.name] || 'secondary' %>"><%= @item.rarity&.name %></span>
        <span class="badge bg-secondary"><%= @item.category&.name %></span>
        <% if @item.requires_attunement %>
          <span class="badge bg-warning text-dark"><i class="bi bi-link-45deg me-1"></i>Attunement</span>
        <% end %>
      </div>
      <table class="table table-sm" style="font-size:0.8125rem;">
        <tbody>
          <tr><td class="text-muted fw-semibold" style="width:130px;"><%= t('items.power') %></td><td><strong><%= @item.power %></strong></td></tr>
          <tr><td class="text-muted fw-semibold"><%= t('items.price') %></td><td><%= number_with_delimiter(@item.price) %> gp</td></tr>
          <tr><td class="text-muted fw-semibold"><%= t('items.weight') %></td><td><%= @item.weight %> lbs</td></tr>
          <tr><td class="text-muted fw-semibold"><%= t('admin.owner') %></td><td><%= @item.user&.full_name || "—" %></td></tr>
          <tr><td class="text-muted fw-semibold"><%= t('shared.created_at') %></td><td><%= @item.created_at.strftime("%b %d, %Y %H:%M") %></td></tr>
        </tbody>
      </table>
      <% if @item.description.present? %>
        <div class="p-3 rounded" style="background:var(--bs-tertiary-bg); font-size:0.8rem; line-height:1.6;">
          <%= @item.description %>
        </div>
      <% end %>
    </div>
  </div>
  <div class="col-lg-5">
    <div class="admin-table-wrap">
      <div class="px-3 py-2" style="border-bottom:1px solid var(--bs-border-color); background:var(--bs-tertiary-bg);">
        <span class="fw-semibold" style="font-size:0.78rem; color:var(--bs-secondary-color); text-transform:uppercase; letter-spacing:0.05em;">
          <i class="bi bi-stars me-1"></i><%= t('items.effects') %>
        </span>
      </div>
      <div class="p-2">
        <% @item.effects.each do |effect| %>
          <div class="d-flex align-items-center gap-2 py-1">
            <span class="badge bg-info rounded-pill" style="font-size:0.6rem; min-width:22px;"><%= effect.power_level %></span>
            <span class="small fw-semibold"><%= effect.name %></span>
            <span class="badge bg-secondary bg-opacity-50 text-secondary ms-auto" style="font-size:0.6rem;"><%= effect.effect_type %></span>
          </div>
        <% end %>
        <% if @item.effects.empty? %>
          <p class="text-muted small text-center my-2"><%= t('shared.no_records') %></p>
        <% end %>
      </div>
    </div>
  </div>
</div>
