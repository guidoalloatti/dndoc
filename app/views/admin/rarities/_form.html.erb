<div class="admin-form-card">
  <%= form_with model: [:admin, rarity], local: true do |f| %>
    <% if rarity.errors.any? %>
      <div class="alert alert-danger mb-3 py-2" style="font-size:0.8rem;">
        <% rarity.errors.full_messages.each do |msg| %>
          <div><i class="bi bi-exclamation-circle me-1"></i><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :name, t('shared.name'), class: "form-label" %>
      <%= f.text_field :name, class: "form-control #{'is-invalid' if rarity.errors[:name].any?}" %>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-6">
        <%= f.label :min_power, t('rarities.min_power'), class: "form-label" %>
        <%= f.number_field :min_power, min: 0, max: 10, class: "form-control" %>
      </div>
      <div class="col-6">
        <%= f.label :max_power, t('rarities.max_power'), class: "form-label" %>
        <%= f.number_field :max_power, min: 0, max: 10, class: "form-control" %>
      </div>
    </div>

    <div class="row g-3 mb-4">
      <div class="col-6">
        <%= f.label :min_price, t('rarities.min_price'), class: "form-label" %>
        <%= f.number_field :min_price, min: 0, class: "form-control" %>
      </div>
      <div class="col-6">
        <%= f.label :max_price, t('rarities.max_price'), class: "form-label" %>
        <%= f.number_field :max_price, min: 0, class: "form-control" %>
      </div>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit t('shared.save'), class: "btn btn-primary" %>
      <%= link_to t('shared.cancel'), admin_rarities_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
