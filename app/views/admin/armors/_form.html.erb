<div class="admin-form-card">
  <%= form_with model: [:admin, armor], local: true do |f| %>
    <% if armor.errors.any? %>
      <div class="alert alert-danger mb-3 py-2" style="font-size:0.8rem;">
        <% armor.errors.full_messages.each do |msg| %>
          <div><i class="bi bi-exclamation-circle me-1"></i><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <div class="row g-3 mb-3">
      <div class="col-8">
        <%= f.label :name, t('shared.name'), class: "form-label" %>
        <%= f.text_field :name, class: "form-control #{'is-invalid' if armor.errors[:name].any?}" %>
      </div>
      <div class="col-4">
        <%= f.label :armor_type, t('armors.armor_type'), class: "form-label" %>
        <%= f.select :armor_type, Armor::TYPES.map { |t| [t, t] }, { include_blank: "—" },
            class: "form-select #{'is-invalid' if armor.errors[:armor_type].any?}" %>
      </div>
    </div>

    <div class="mb-3">
      <%= f.label :armor_class, t('armors.armor_class'), class: "form-label" %>
      <div class="d-flex align-items-center gap-2">
        <span class="text-muted small fw-semibold">AC</span>
        <%= f.text_field :armor_class, placeholder: "e.g. 11 + Dex mod, 14 + Dex mod (max 2), 18",
            class: "form-control #{'is-invalid' if armor.errors[:armor_class].any?}" %>
      </div>
      <div class="form-text"><%= t('armors.armor_class_hint') %></div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-4">
        <%= f.label :cost, t('armors.cost') + " (gp)", class: "form-label" %>
        <%= f.number_field :cost, step: 1, min: 0, class: "form-control" %>
      </div>
      <div class="col-4">
        <%= f.label :weight, t('armors.weight') + " (lb)", class: "form-label" %>
        <%= f.number_field :weight, step: 0.5, min: 0, class: "form-control" %>
      </div>
      <div class="col-4">
        <%= f.label :str_requirement, t('armors.str_req'), class: "form-label" %>
        <%= f.number_field :str_requirement, step: 1, min: 0, placeholder: "—",
            class: "form-control" %>
        <div class="form-text"><%= t('armors.str_req_hint') %></div>
      </div>
    </div>

    <div class="mb-3">
      <div class="form-check">
        <%= f.check_box :stealth_disadvantage, class: "form-check-input" %>
        <%= f.label :stealth_disadvantage, t('armors.stealth_disadv'), class: "form-check-label" %>
      </div>
    </div>

    <div class="mb-4">
      <%= f.label :properties, t('armors.properties'), class: "form-label" %>
      <%= f.text_area :properties, rows: 2,
          placeholder: "e.g. Covers the torso, legs, and feet. Must be proficient to wear.",
          class: "form-control" %>
    </div>

    <div class="d-flex gap-2">
      <%= f.submit t('shared.save'), class: "btn btn-primary" %>
      <%= link_to t('shared.cancel'), admin_armors_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
