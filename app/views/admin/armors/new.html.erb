<% content_for :admin_breadcrumb do %>
  <span class="admin-breadcrumb">
    <a href="<%= admin_root_path %>"><%= t('admin.dashboard') %></a>
    <span class="sep">/</span>
    <a href="<%= admin_armors_path %>"><%= t('nav.armors') %></a>
    <span class="sep">/</span>
    <span class="current"><%= t('admin.armors.new') %></span>
