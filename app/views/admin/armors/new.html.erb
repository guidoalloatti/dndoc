<% end %>
<div class="admin-page-header">
  <div class="admin-page-title">
    <div class="admin-title-icon bg-warning bg-opacity-10"><i class="bi bi-shield-plus text-warning"></i></div>
    <div><h5><%= t('admin.armors.new') %></h5></div>
  </div>
</div>
<%= render 'form', armor: @armor %>
