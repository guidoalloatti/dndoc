<div class="container mt-4" style="max-width: 560px;">
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0 fw-bold">
      <i class="bi bi-pencil-square text-primary me-1"></i> <%= t('weapons.edit') %>
    </h4>
    <%= link_to weapons_path, class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i><%= t('shared.back') %>
    <% end %>
  </div>
  <%= render 'form', weapon: @weapon %>
</div>
