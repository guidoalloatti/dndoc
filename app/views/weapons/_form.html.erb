<%= form_with(model: weapon, local: true) do |form| %>
  <% if weapon.errors.any? %>
    <div class="alert alert-danger py-2 small">
      <i class="bi bi-exclamation-triangle me-1"></i>
      <strong><%= pluralize(weapon.errors.count, "error") %>:</strong>
      <ul class="mb-0 mt-1">
        <% weapon.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="mb-3">
        <%= form.label :name, t('shared.name'), class: "form-label small fw-semibold" %>
        <%= form.text_field :name, class: "form-control form-control-sm", placeholder: "Weapon name" %>
      </div>

      <div class="row g-3 mb-3">
        <div class="col-sm-4">
          <%= form.label :cost, t('weapons.cost'), class: "form-label small fw-semibold" %>
          <%= form.text_field :cost, class: "form-control form-control-sm", placeholder: "e.g. 25 gp" %>
        </div>
        <div class="col-sm-4">
          <%= form.label :damage, t('weapons.damage'), class: "form-label small fw-semibold" %>
          <%= form.text_field :damage, class: "form-control form-control-sm", placeholder: "e.g. 1d8" %>
        </div>
        <div class="col-sm-4">
          <%= form.label :weight, t('weapons.weight'), class: "form-label small fw-semibold" %>
          <%= form.text_field :weight, class: "form-control form-control-sm", placeholder: "e.g. 3 lb." %>
        </div>
      </div>

      <div class="mb-0">
        <%= form.label :properties, t('weapons.properties'), class: "form-label small fw-semibold" %>
        <%= form.text_area :properties, class: "form-control form-control-sm", rows: 2, placeholder: "e.g. Versatile (1d10), Finesse..." %>
      </div>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <%= form.submit weapon.persisted? ? t('shared.update') : t('shared.create'), class: "btn btn-sm btn-primary" %>
    <%= link_to t('shared.cancel'), weapons_path, class: "btn btn-sm btn-outline-secondary" %>
  </div>
<% end %>
