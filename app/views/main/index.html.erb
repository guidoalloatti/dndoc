  @keyframes scrollChev { 0%, 100% { opacity: 0.2; } 50% { opacity: 1; } }
  @keyframes scrollPulse { 0%, 100% { bottom: 32px; } 50% { bottom: 24px; } }

  /* ─────────────────────────────────────
     SCROLL REVEAL BASE STATES
  ───────────────────────────────────── */
  .lp-sr[data-sr="fade-up"]    { opacity: 0; transform: translateY(40px); transition: opacity 0.65s ease, transform 0.65s ease; }
