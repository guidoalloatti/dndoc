  @keyframes rwIn  { from { opacity: 0; transform: translateY(16px) scale(0.9); } to { opacity: 1; transform: none; } }
  @keyframes rwOut { from { opacity: 1; } to { opacity: 0; transform: translateY(-10px); } }
  .lp-hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.2rem);
