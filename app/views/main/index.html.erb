  .lp-depth-orb-2 { width: 450px; height: 450px; bottom: -100px; right: -100px; background: radial-gradient(circle, rgba(139,92,246,0.6), transparent 70%); }
  .lp-depth-orb-3 { width: 320px; height: 320px; top: 40%; left: 55%; background: radial-gradient(circle, rgba(16,185,129,0.5), transparent 70%); }
