    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 900px) { .lp-tools-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .lp-tools-grid { grid-template-columns: 1fr; } }
  .lp-tool-card {
    padding: 28px 24px 24px;
    border-radius: 16px;
    border: 1px solid var(--bs-border-color);
    background: var(--bs-body-bg);
    display: flex; flex-direction: column;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    position: relative; overflow: hidden;
  }
  .lp-tool-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--tc), transparent);
    opacity: 0; transition: opacity 0.25s ease;
  }
  .lp-tool-card:hover { transform: translateY(-5px); box-shadow: 0 16px 40px var(--tc-glow); border-color: var(--tc); }
  .lp-tool-card:hover::before { opacity: 1; }
  [data-bs-theme="dark"] .lp-tool-card:hover { box-shadow: 0 16px 40px color-mix(in srgb, var(--tc) 25%, transparent); }
  .lp-tool-icon {
    width: 52px; height: 52px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem; margin-bottom: 16px;
    background: color-mix(in srgb, var(--tc) 14%, transparent);
    color: var(--tc); flex-shrink: 0;
    transition: box-shadow 0.25s ease;
  }
  .lp-tool-card:hover .lp-tool-icon { box-shadow: 0 0 20px color-mix(in srgb, var(--tc) 40%, transparent); }
  .lp-tool-title { font-size: 1rem; font-weight: 700; margin: 0 0 8px; }
  .lp-tool-desc  { font-size: 0.82rem; color: var(--bs-secondary-color); line-height: 1.6; margin: 0 0 16px; flex: 1; }
  .lp-tool-cta {
    display: inline-flex; align-items: center;
    font-size: 0.78rem; font-weight: 700; color: var(--tc);
    text-decoration: none; margin-top: auto;
    transition: gap 0.2s ease;
    gap: 2px;
  }
  .lp-tool-cta:hover { color: var(--tc); gap: 6px; }

  /* ─────────────────────────────────────
     PARTY SECTION
  ───────────────────────────────────── */
  .lp-section-party { background: var(--bs-tertiary-bg); }
  .lp-party-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: center;
  }
  @media (max-width: 800px) { .lp-party-inner { grid-template-columns: 1fr; gap: 40px; } }

  .lp-party-features { display: flex; flex-direction: column; gap: 20px; }
  .lp-party-feature { display: flex; align-items: flex-start; gap: 16px; }
  .lp-party-feature-dot {
    width: 38px; height: 38px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 0.85rem;
  }
  .lp-party-feature-title { font-size: 0.9rem; font-weight: 700; margin-bottom: 3px; }
  .lp-party-feature-desc  { font-size: 0.8rem; color: var(--bs-secondary-color); line-height: 1.5; }

  /* Party mockup card */
  .lp-party-mockup { position: relative; }
  .lp-mock-card {
    border-radius: 18px;
    background: #0d1117;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    overflow: hidden;
  }
  [data-bs-theme="light"] .lp-mock-card { background: #1a1d27; }
  .lp-mock-party-header {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 20px; border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .lp-mock-party-shield {
    width: 36px; height: 36px; border-radius: 10px;
    background: rgba(167,139,250,0.2); color: #a78bfa;
    display: flex; align-items: center; justify-content: center; font-size: 1rem;
    flex-shrink: 0;
  }
  .lp-mock-party-name { font-size: 0.9rem; font-weight: 800; color: #fff; }
  .lp-mock-party-meta { font-size: 0.62rem; color: rgba(255,255,255,0.4); margin-top: 1px; }
  .lp-mock-reward-badge {
    margin-left: auto; flex-shrink: 0;
    font-size: 0.6rem; font-weight: 700; padding: 4px 10px; border-radius: 6px;
    background: rgba(251,191,36,0.15); color: #fbbf24;
    border: 1px solid rgba(251,191,36,0.25);
  }
  .lp-mock-chars { padding: 8px 12px; display: flex; flex-direction: column; gap: 2px; }
  .lp-mock-char {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 8px; border-radius: 10px;
    transition: background 0.15s ease;
  }
  .lp-mock-char:hover { background: rgba(255,255,255,0.04); }
  .lp-mock-char-avatar {
    width: 36px; height: 36px; border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: var(--char-color); font-size: 1rem; flex-shrink: 0;
  }
  .lp-mock-char-info { flex: 1; min-width: 0; }
  .lp-mock-char-name { font-size: 0.8rem; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .lp-mock-char-meta { display: flex; align-items: center; gap: 6px; margin-top: 2px; }
  .lp-mock-class-badge { font-size: 0.58rem; font-weight: 700; padding: 2px 7px; border-radius: 5px; }
  .lp-mock-race { font-size: 0.6rem; color: rgba(255,255,255,0.4); }
  .lp-mock-char-right { text-align: right; flex-shrink: 0; }
  .lp-mock-lv   { font-size: 0.68rem; font-weight: 800; color: var(--char-color); }
  .lp-mock-items { font-size: 0.6rem; color: rgba(255,255,255,0.4); margin-top: 1px; }
  .lp-mock-forge-btn {
    margin: 8px 12px 12px;
    padding: 11px; border-radius: 10px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    color: #fff; font-size: 0.8rem; font-weight: 700;
    text-align: center; cursor: default;
    box-shadow: 0 4px 16px rgba(99,102,241,0.4);
  }

  /* Floating item chips */
  .lp-mock-floating {
    position: absolute;
    display: flex; align-items: center; gap: 6px;
    padding: 8px 14px; border-radius: 999px;
    background: rgba(13,17,23,0.92); border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(12px);
    font-size: 0.72rem; font-weight: 600; color: #fff;
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    white-space: nowrap;
  }
  [data-bs-theme="light"] .lp-mock-floating { background: rgba(26,29,39,0.92); }
  .lp-mock-float-badge { font-size: 0.6rem; font-weight: 700; }
  .lp-mock-float-1 { top: -18px; right: -20px; animation: floatDrift 4s ease-in-out infinite; }
  .lp-mock-float-2 { bottom: 60px; left: -28px; animation: floatDrift 5s ease-in-out infinite reverse; }
  .lp-mock-float-3 { bottom: -18px; right: 20px; animation: floatDrift 3.5s ease-in-out infinite 1s; }
  @keyframes floatDrift {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }
  @media (max-width: 800px) {
    .lp-mock-float-1, .lp-mock-float-2, .lp-mock-float-3 { display: none; }
  }

  /* ─────────────────────────────────────
     RARITY
  ───────────────────────────────────── */
  .lp-section-rarity { background: var(--bs-tertiary-bg); }
  .lp-rarity-track {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
  }
  .lp-rarity-card {
    padding: 28px 16px 20px;
    border-radius: 14px;
    border: 1px solid color-mix(in srgb, var(--rc) 25%, transparent);
    background: var(--rc-bg);
    text-align: center;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    cursor: default;
  }
  .lp-rarity-card:hover {
    transform: translateY(-5px) scale(1.03);
    box-shadow: 0 0 30px color-mix(in srgb, var(--rc) 30%, transparent);
  }
  .lp-rarity-gem { font-size: 2rem; color: var(--rc); margin-bottom: 10px; animation: gemPulse 3s ease-in-out infinite; }
  @keyframes gemPulse { 0%, 100% { filter: brightness(1); } 50% { filter: brightness(1.4) drop-shadow(0 0 6px var(--rc)); } }
  .lp-rarity-name { font-size: 0.82rem; font-weight: 800; color: var(--rc); margin-bottom: 6px; }
  .lp-rarity-stat { font-size: 0.65rem; color: var(--bs-secondary-color); line-height: 1.8; }

  /* ─────────────────────────────────────
     SHOWCASE
  ───────────────────────────────────── */
  .lp-section-showcase { background: var(--bs-body-bg); }
  .lp-showcase-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: center;
  }
  @media (max-width: 768px) {
    .lp-showcase-inner { grid-template-columns: 1fr; gap: 40px; }
  }
  .lp-item-card {
    position: relative;
    padding: 28px;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--item-color) 30%, transparent);
    background: color-mix(in srgb, var(--item-color) 6%, var(--bs-body-bg));
    transition: transform 0.25s ease;
    will-change: transform;
    overflow: hidden;
  }
  .lp-item-card-glow {
    position: absolute; inset: -1px; border-radius: 18px; pointer-events: none;
    box-shadow: 0 0 40px color-mix(in srgb, var(--item-color) 20%, transparent);
    transition: box-shadow 0.3s ease;
  }
  .lp-item-card:hover .lp-item-card-glow { box-shadow: 0 0 60px color-mix(in srgb, var(--item-color) 35%, transparent); }
  .lp-item-header { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 16px; }
  .lp-item-icon {
    width: 48px; height: 48px; border-radius: 12px;
    background: color-mix(in srgb, var(--item-color) 18%, transparent);
    color: var(--item-color); font-size: 1.3rem;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .lp-item-meta { flex: 1; min-width: 0; }
  .lp-item-name { font-size: 1.15rem; font-weight: 800; margin: 0 0 6px; }
  .lp-item-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .lp-tag {
    font-size: 0.6rem; font-weight: 700; padding: 3px 8px; border-radius: 6px;
    background: var(--bs-tertiary-bg); color: var(--bs-secondary-color); letter-spacing: .04em;
  }
  .lp-tag-rarity { background: color-mix(in srgb, var(--item-color) 18%, transparent); color: var(--item-color); }
  .lp-item-power { text-align: center; flex-shrink: 0; }
  .lp-item-power span { display: block; font-size: 1.8rem; font-weight: 900; color: var(--item-color); line-height: 1; }
  .lp-item-power small { font-size: 0.55rem; text-transform: uppercase; letter-spacing: .1em; color: var(--bs-secondary-color); }
  .lp-item-desc { font-size: 0.82rem; color: var(--bs-secondary-color); line-height: 1.6; margin: 0 0 16px; }
  .lp-item-effects { display: flex; flex-wrap: wrap; gap: 6px; }
  .lp-effect-chip {
    font-size: 0.68rem; padding: 4px 10px; border-radius: 7px; font-weight: 600;
    display: flex; align-items: center; gap: 5px;
  }
  .lp-effect-primary  { background: rgba(99,102,241,0.12); color: #818cf8; }
  .lp-effect-success  { background: rgba(16,185,129,0.12); color: #34d399; }
  .lp-effect-warning  { background: rgba(245,158,11,0.12); color: #fbbf24; }
  .lp-effect-danger   { background: rgba(239,68,68,0.12);  color: #fca5a5; }
  .lp-effect-info     { background: rgba(14,165,233,0.12); color: #38bdf8; }
  .lp-effect-secondary{ background: rgba(100,116,139,0.12);color: #94a3b8; }

  /* ─────────────────────────────────────
     STEPS
  ───────────────────────────────────── */
  .lp-section-steps { background: var(--bs-tertiary-bg); }
  .lp-steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  @media (max-width: 640px) { .lp-steps { grid-template-columns: 1fr; } }
  .lp-steps-line {
    position: absolute; top: 26px; left: calc(16.66% + 26px); right: calc(16.66% + 26px);
    height: 2px; background: linear-gradient(to right, #6366f1, #10b981);
    opacity: 0.3; z-index: 0;
  }
  @media (max-width: 640px) { .lp-steps-line { display: none; } }
  .lp-step { text-align: center; position: relative; z-index: 1; }
  .lp-step-dot {
    width: 52px; height: 52px; border-radius: 50%;
    background: color-mix(in srgb, var(--step-color) 18%, var(--bs-body-bg));
    border: 2px solid color-mix(in srgb, var(--step-color) 40%, transparent);
    color: var(--step-color); font-size: 1.2rem;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 8px;
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--step-color) 10%, transparent);
    transition: box-shadow 0.25s ease;
  }
  .lp-step:hover .lp-step-dot { box-shadow: 0 0 0 8px color-mix(in srgb, var(--step-color) 15%, transparent); }
  .lp-step-num { font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: var(--bs-secondary-color); margin-bottom: 12px; }
  .lp-step-title { font-size: 1rem; font-weight: 700; margin: 0 0 8px; }
  .lp-step-desc  { font-size: 0.82rem; color: var(--bs-secondary-color); line-height: 1.6; margin: 0; }

  /* ─────────────────────────────────────
     CTA
  ───────────────────────────────────── */
  .lp-section-cta {
    position: relative; overflow: hidden;
    background: #050810;
    padding: 120px 0;
    text-align: center;
  }
  .lp-cta-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 80% at 25% 50%, rgba(99,102,241,0.40) 0%, transparent 60%),
      radial-gradient(ellipse 65% 65% at 75% 35%, rgba(139,92,246,0.32) 0%, transparent 55%),
      radial-gradient(ellipse 50% 50% at 50% 80%, rgba(16,185,129,0.18) 0%, transparent 50%);
  }
  .lp-cta-sparks { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
  .lp-cta-content { position: relative; z-index: 2; }
  .lp-cta-icon { font-size: 3rem; color: #818cf8; margin-bottom: 20px; animation: ctaIconFloat 3s ease-in-out infinite; }
  @keyframes ctaIconFloat { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-12px) rotate(8deg); } }
  .lp-cta-title { font-size: clamp(1.8rem, 5vw, 3rem); font-weight: 900; color: #fff; margin: 0 0 16px; text-shadow: 0 0 40px rgba(99,102,241,0.4); }
  .lp-cta-sub { color: rgba(255,255,255,0.5); max-width: 500px; margin: 0 auto 40px; line-height: 1.7; font-size: 1rem; }
  .lp-cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  /* ─── Dark/light color-mix fallback ─── */
  @supports not (background: color-mix(in srgb, red 10%, white)) {
    .lp-rarity-card  { background: rgba(128,128,128,0.08); }
    .lp-feature-icon { background: rgba(99,102,241,0.12); color: var(--icon-color); }
  }
  </style>
<% end %>
