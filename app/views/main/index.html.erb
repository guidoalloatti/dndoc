<% if user_signed_in? %>
  <%# ══════════════════════════════════════════════════════ %>
  <%# DASHBOARD — signed-in user view                       %>
  <%# ══════════════════════════════════════════════════════ %>
  <div class="container py-4">
    <%# Welcome row %>
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h3 class="fw-bold mb-1"><%= t('home.welcome_back', name: current_user.first_name || current_user.email.split('@').first) %></h3>
        <p class="text-body-secondary mb-0"><%= t('home.dashboard_subtitle') %></p>
      </div>
      <%= link_to create_random_items_path, class: 'btn btn-primary px-4 shadow-sm' do %>
        <i class="bi bi-lightning-fill me-1"></i> <%= t('home.generate_item') %>
      <% end %>
    </div>

    <%# User stats %>
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body py-3 text-center">
            <div class="text-primary fs-3 fw-bold"><%= @user_items_count %></div>
            <small class="text-body-secondary fw-medium"><%= t('home.my_items') %></small>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body py-3 text-center">
            <div class="text-success fs-3 fw-bold"><%= @stats[:effects] %></div>
            <small class="text-body-secondary fw-medium"><%= t('home.stats_effects') %></small>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body py-3 text-center">
            <div class="text-info fs-3 fw-bold"><%= @stats[:categories] %></div>
            <small class="text-body-secondary fw-medium"><%= t('home.stats_categories') %></small>
          </div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body py-3 text-center">
            <div class="text-danger fs-3 fw-bold"><%= @stats[:weapons] %></div>
            <small class="text-body-secondary fw-medium"><%= t('home.stats_weapons') %></small>
          </div>
        </div>
      </div>
    </div>

    <%# Recent items %>
    <% if @recent_items.any? %>
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i><%= t('home.recent_items') %></h5>
        <%= link_to items_path, class: 'btn btn-sm btn-outline-primary' do %>
          <%= t('home.view_all') %> <i class="bi bi-arrow-right ms-1"></i>
        <% end %>
      </div>
      <div class="row g-3 mb-4">
        <% @recent_items.each do |item| %>
          <div class="col-md-6 col-lg-4">
            <%= link_to item_path(item), class: 'text-decoration-none' do %>
              <div class="index-card rarity-<%= rarity_css_class(item.rarity.name) %> h-100">
                <div class="d-flex align-items-start gap-2">
                  <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px;">
                    <i class="bi bi-<%= category_icon(item.category.name) %> text-primary" style="font-size: 0.9rem;"></i>
                  </div>
                  <div class="flex-grow-1 min-width-0">
                    <div class="card-title text-body text-truncate"><%= item.name %></div>
                    <div class="d-flex align-items-center gap-1 flex-wrap">
                      <span class="badge <%= rarity_badge_class(item.rarity.name) %>" style="font-size: 0.6rem;"><%= item.rarity.name %></span>
                      <span class="badge bg-body-secondary text-body" style="font-size: 0.6rem;"><%= item.category.name %></span>
                    </div>
                    <div class="card-stats mt-1">
                      <span class="stat-item"><i class="bi bi-lightning-charge text-warning"></i> <%= item.power %></span>
                      <span class="stat-item"><i class="bi bi-coin text-warning"></i> <%= number_with_delimiter(item.price) %></span>
                      <span class="stat-item"><i class="bi bi-magic text-info"></i> <%= item.effects.size %></span>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <%# New user — empty state %>
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body py-5 text-center">
          <div class="landing-icon-circle bg-primary bg-opacity-10 mx-auto mb-3">
            <i class="bi bi-box-seam text-primary" style="font-size: 2rem;"></i>
          </div>
          <h5 class="fw-bold mb-2"><%= t('home.no_items_title') %></h5>
          <p class="text-body-secondary mb-3"><%= t('home.no_items_desc') %></p>
          <div class="d-flex justify-content-center gap-2">
            <%= link_to create_random_items_path, class: 'btn btn-primary' do %>
              <i class="bi bi-lightning-fill me-1"></i> <%= t('home.generate_item') %>
            <% end %>
            <%= link_to new_item_path, class: 'btn btn-outline-primary' do %>
              <i class="bi bi-plus-lg me-1"></i> <%= t('home.create_manual') %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# Quick access cards %>
    <h5 class="fw-bold text-body-secondary mb-3">
      <i class="bi bi-grid-3x2-gap me-1"></i> <%= t('home.quick_access') %>
    </h5>
    <div class="row g-3">
      <div class="col-6 col-md-4 col-lg-2">
        <%= link_to new_item_path, class: 'text-decoration-none' do %>
          <div class="card border-0 shadow-sm card-hover text-center h-100">
            <div class="card-body py-3">
              <i class="bi bi-plus-circle text-primary fs-4"></i>
              <div class="small fw-semibold mt-1"><%= t('nav.new_item') %></div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <%= link_to create_random_items_path, class: 'text-decoration-none' do %>
          <div class="card border-0 shadow-sm card-hover text-center h-100">
            <div class="card-body py-3">
              <i class="bi bi-dice-5 text-success fs-4"></i>
              <div class="small fw-semibold mt-1"><%= t('items.random') %></div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <%= link_to items_path, class: 'text-decoration-none' do %>
          <div class="card border-0 shadow-sm card-hover text-center h-100">
            <div class="card-body py-3">
              <i class="bi bi-box-seam text-info fs-4"></i>
              <div class="small fw-semibold mt-1"><%= t('nav.items') %></div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <%= link_to effects_path, class: 'text-decoration-none' do %>
          <div class="card border-0 shadow-sm card-hover text-center h-100">
            <div class="card-body py-3">
              <i class="bi bi-magic text-warning fs-4"></i>
              <div class="small fw-semibold mt-1"><%= t('nav.effects') %></div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <%= link_to categories_path, class: 'text-decoration-none' do %>
          <div class="card border-0 shadow-sm card-hover text-center h-100">
            <div class="card-body py-3">
              <i class="bi bi-grid text-danger fs-4"></i>
              <div class="small fw-semibold mt-1"><%= t('nav.categories') %></div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="col-6 col-md-4 col-lg-2">
        <%= link_to weapons_path, class: 'text-decoration-none' do %>
          <div class="card border-0 shadow-sm card-hover text-center h-100">
            <div class="card-body py-3">
              <i class="bi bi-shield-shaded text-secondary fs-4"></i>
              <div class="small fw-semibold mt-1"><%= t('nav.weapons') %></div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

<% else %>
  <%# ══════════════════════════════════════════════════════ %>
  <%# LANDING PAGE — not signed in                          %>
  <%# ══════════════════════════════════════════════════════ %>
  <% content_for :body_class, "landing-page" %>

  <%# ─────────────────────────────────────────────────────
      FLOATING NAV
  ───────────────────────────────────────────────────────── %>
  <nav class="lp-nav" id="lp-nav">
    <a href="#lp-hero" class="lp-nav-brand">
      <i class="bi bi-fire"></i>
      <span><%= t('landing.app_name') %></span>
      <em><%= t('landing.app_tagline') %></em>
    </a>
    <div class="lp-nav-actions">
      <div class="lp-nav-langs">
        <a href="<%= url_for(locale: :es) %>" class="<%= 'on' if I18n.locale == :es %>">ES</a>
        <span>|</span>
        <a href="<%= url_for(locale: :en) %>" class="<%= 'on' if I18n.locale == :en %>">EN</a>
      </div>
      <%= link_to new_user_session_path, class: "lp-nav-login" do %>
        <i class="bi bi-person-fill me-1"></i><%= t('landing.nav_login') %>
      <% end %>
      <%= link_to new_user_registration_path, class: "lp-nav-signup" do %>
        <i class="bi bi-rocket-takeoff me-1"></i><%= t('landing.nav_signup') %>
      <% end %>
    </div>
  </nav>

  <%# ─────────────────────────────────────────────────────
      HERO — Full-viewport cinematic hero
  ───────────────────────────────────────────────────────── %>
  <section class="lp-hero" id="lp-hero">
    <%# Aurora background %>
    <div class="lp-hero-aurora">
      <div class="lp-aurora lp-aurora-1"></div>
      <div class="lp-aurora lp-aurora-2"></div>
      <div class="lp-aurora lp-aurora-3"></div>
      <div class="lp-aurora lp-aurora-4"></div>
    </div>
    <%# Deep star field %>
    <canvas class="lp-starfield" id="lp-starfield"></canvas>
    <%# Noise texture %>
    <div class="lp-hero-noise"></div>
    <%# Cursor spotlight %>
    <div class="lp-cursor-spotlight" id="lp-spotlight"></div>
    <%# Mouse-tracking depth layer %>
    <div class="lp-hero-depth" id="lp-depth">
      <div class="lp-depth-orb lp-depth-orb-1" data-depth="0.05"></div>
      <div class="lp-depth-orb lp-depth-orb-2" data-depth="0.03"></div>
      <div class="lp-depth-orb lp-depth-orb-3" data-depth="0.07"></div>
      <div class="lp-depth-orb lp-depth-orb-4" data-depth="0.04"></div>
    </div>
    <%# Floating runes — bigger, more vivid %>
    <div class="lp-hero-runes" data-parallax="0.18">
      <span class="lp-rune lp-rune-1"><i class="bi bi-lightning-charge-fill"></i></span>
      <span class="lp-rune lp-rune-2"><i class="bi bi-shield-fill"></i></span>
      <span class="lp-rune lp-rune-3"><i class="bi bi-gem"></i></span>
      <span class="lp-rune lp-rune-4"><i class="bi bi-magic"></i></span>
      <span class="lp-rune lp-rune-5"><i class="bi bi-dice-5-fill"></i></span>
      <span class="lp-rune lp-rune-6"><i class="bi bi-fire"></i></span>
      <span class="lp-rune lp-rune-7"><i class="bi bi-stars"></i></span>
      <span class="lp-rune lp-rune-8"><i class="bi bi-globe-americas"></i></span>
    </div>

    <div class="lp-hero-content" data-parallax="0.08">
      <div class="lp-hero-badge lp-anim" data-lp-delay="0">
        <i class="bi bi-fire"></i> <%= t('landing.app_name') %>
        <span class="lp-hero-badge-sep"></span>
        <span class="lp-hero-badge-tag"><%= t('landing.app_tagline') %></span>
      </div>
      <h1 class="lp-hero-title lp-anim" data-lp-delay="100">
        <span class="lp-title-forge">Forge</span>
        <span class="lp-rotate-wrap" id="lp-rotate-wrap">
          <span class="lp-rw lp-rw-active">Artifacts</span>
          <span class="lp-rw">Legends</span>
          <span class="lp-rw">Destiny</span>
          <span class="lp-rw">Weapons</span>
          <span class="lp-rw">History</span>
        </span>
        <br><span class="lp-title-across">Across Every Legend</span>
      </h1>
      <p class="lp-hero-sub lp-anim" data-lp-delay="250">
        <%= t('landing.hero_subtitle') %>
      </p>
      <div class="lp-hero-ctas lp-anim" data-lp-delay="380">
        <%= link_to new_user_registration_path, class: "lp-btn-primary" do %>
          <i class="bi bi-rocket-takeoff me-2"></i><%= t('landing.get_started') %>
        <% end %>
        <a href="#lp-features" class="lp-btn-ghost">
          <i class="bi bi-play-circle me-2"></i><%= t('landing.explore') %>
        </a>
      </div>
      <div class="lp-hero-stats lp-anim" data-lp-delay="500">
        <% [
             [@stats[:lore],   t('landing.stat_lore'),    'bi-book-fill',          '#818cf8'],
             [@stats[:items],  t('landing.stat_items'),   'bi-box-seam-fill',      '#34d399'],
             [@stats[:effects],t('landing.stat_effects'), 'bi-stars',              '#fbbf24'],
             [@stats[:lore_worlds], t('landing.stat_worlds'), 'bi-globe-americas', '#38bdf8'],
           ].each do |(val, label, icon, color)| %>
          <div class="lp-stat">
            <i class="bi <%= icon %> lp-stat-icon" style="color:<%= color %>;"></i>
            <span class="lp-stat-num counter" data-count="<%= val %>">0</span>
            <span class="lp-stat-label"><%= label %></span>
          </div>
        <% end %>
      </div>
    </div>

    <div class="lp-hero-scroll-hint">
      <span></span><span></span><span></span>
    </div>
  </section>

  <%# ─────────────────────────────────────────────────────
      MARQUEE — scrolling world/category ticker
  ───────────────────────────────────────────────────────── %>
  <div class="lp-marquee-wrap">
    <% marquee_items = [
         { icon: 'globe-americas', text: 'Faerûn',        color: '#818cf8' },
         { icon: 'tree',           text: 'Middle-earth',  color: '#34d399' },
         { icon: 'lightning-charge-fill', text: 'Instant Forge', color: '#fbbf24' },
         { icon: 'shield-fill',    text: 'Armor',         color: '#fb923c' },
         { icon: 'hammer',         text: 'Weapons',       color: '#f87171' },
         { icon: 'magic',          text: 'Item Wizard',   color: '#a78bfa' },
         { icon: 'book-fill',      text: 'Lore Engine',   color: '#38bdf8' },
         { icon: 'gem',            text: 'Ancestral',     color: '#fbbf24' },
         { icon: 'people-fill',    text: 'Party Rewards', color: '#4ade80' },
         { icon: 'stars',          text: 'Synergies',     color: '#f472b6' },
         { icon: 'dice-5-fill',    text: 'Random Forge',  color: '#818cf8' },
         { icon: 'person-badge-fill', text: 'Characters', color: '#34d399' },
       ] %>
    <div class="lp-marquee">
      <div class="lp-marquee-track">
        <% (marquee_items * 2).each do |item| %>
          <span class="lp-marquee-item" style="--mi-color:<%= item[:color] %>;">
            <i class="bi bi-<%= item[:icon] %>"></i><%= item[:text] %>
          </span>
        <% end %>
      </div>
      <div class="lp-marquee-track" aria-hidden="true">
        <% (marquee_items * 2).each do |item| %>
          <span class="lp-marquee-item" style="--mi-color:<%= item[:color] %>;">
            <i class="bi bi-<%= item[:icon] %>"></i><%= item[:text] %>
          </span>
        <% end %>
      </div>
    </div>
  </div>

  <%# ─────────────────────────────────────────────────────
      BY THE NUMBERS — full lore + entity stats
  ───────────────────────────────────────────────────────── %>
  <section class="lp-section lp-section-numbers">
    <div class="lp-container">
      <div class="lp-section-header lp-sr" data-sr="fade-up">
        <span class="lp-pill lp-pill-primary">
          <i class="bi bi-bar-chart-fill me-1"></i><%= t('landing.numbers_badge') %>
        </span>
        <h2 class="lp-section-title lp-gradient-title"><%= t('landing.numbers_title') %></h2>
        <p class="lp-section-sub"><%= t('landing.numbers_subtitle') %></p>
      </div>

      <div class="lp-numbers-grid">
        <% [
             { val: @stats[:lore],              label: t('landing.num_lore_label'),        icon: 'book-fill',          color: '#818cf8', bg: 'rgba(129,140,248,0.1)', highlight: true },
             { val: @stats[:items],             label: t('landing.num_items_label'),        icon: 'box-seam-fill',      color: '#34d399', bg: 'rgba(52,211,153,0.1)' },
             { val: @stats[:effects],           label: t('landing.num_effects_label'),      icon: 'stars',              color: '#fbbf24', bg: 'rgba(251,191,36,0.1)' },
             { val: @stats[:lore_worlds],       label: t('landing.num_worlds_label'),       icon: 'globe-americas',     color: '#38bdf8', bg: 'rgba(56,189,248,0.1)' },
             { val: @stats[:categories],        label: t('landing.num_categories_label'),   icon: 'grid-3x3-gap-fill',  color: '#f472b6', bg: 'rgba(244,114,182,0.1)' },
             { val: @stats[:weapons] + @stats[:armors], label: t('landing.num_weapons_label'), icon: 'shield-fill',    color: '#fb923c', bg: 'rgba(251,146,60,0.1)' },
             { val: @stats[:parties],           label: t('landing.num_parties_label'),      icon: 'shield-fill',        color: '#a78bfa', bg: 'rgba(167,139,250,0.1)' },
             { val: @stats[:characters],        label: t('landing.num_characters_label'),   icon: 'person-badge-fill',  color: '#4ade80', bg: 'rgba(74,222,128,0.1)' },
             { val: @stats[:character_classes], label: t('landing.num_classes_label'),      icon: 'mortarboard-fill',   color: '#f87171', bg: 'rgba(248,113,113,0.1)' },
           ].each_with_index do |n, i| %>
          <div class="lp-num-card lp-sr <%= n[:highlight] ? 'lp-num-card-highlight' : '' %>"
               data-sr="scale-up" data-sr-delay="<%= i * 70 %>"
               style="--nc:#{ n[:color] };--nc-bg:#{ n[:bg] };">
            <div class="lp-num-icon"><i class="bi bi-<%= n[:icon] %>"></i></div>
            <div class="lp-num-value counter" data-count="<%= n[:val] %>">0</div>
            <div class="lp-num-label"><%= n[:label] %></div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# ─────────────────────────────────────────────────────
      TOOLS — 6-card arsenal grid
  ───────────────────────────────────────────────────────── %>
  <section class="lp-section lp-section-tools" id="lp-features">
    <div class="lp-container">
      <div class="lp-section-header lp-sr" data-sr="fade-up">
        <span class="lp-pill lp-pill-primary">
          <i class="bi bi-tools me-1"></i><%= t('landing.tools_badge') %>
        </span>
        <h2 class="lp-section-title lp-gradient-title"><%= t('landing.tools_title') %></h2>
        <p class="lp-section-sub"><%= t('landing.tools_subtitle') %></p>
      </div>

      <div class="lp-tools-grid">
        <% tools = [
             { icon: 'lightning-charge-fill', color: '#6366f1', glow: 'rgba(99,102,241,0.3)', path: new_user_registration_path,
               title: t('landing.tool_random_title'), desc: t('landing.tool_random_desc'), cta: t('landing.tool_random_cta') },
             { icon: 'magic',                 color: '#10b981', glow: 'rgba(16,185,129,0.3)', path: new_user_registration_path,
               title: t('landing.tool_wizard_title'), desc: t('landing.tool_wizard_desc'), cta: t('landing.tool_wizard_cta') },
             { icon: 'people-fill',           color: '#f59e0b', glow: 'rgba(245,158,11,0.3)', path: new_user_registration_path,
               title: t('landing.tool_party_title'), desc: t('landing.tool_party_desc'), cta: t('landing.tool_party_cta') },
             { icon: 'book-fill',             color: '#ef4444', glow: 'rgba(239,68,68,0.3)', path: new_user_registration_path,
               title: t('landing.tool_lore_title'), desc: t('landing.tool_lore_desc'), cta: t('landing.tool_lore_cta') },
             { icon: 'diagram-3-fill',        color: '#8b5cf6', glow: 'rgba(139,92,246,0.3)', path: new_user_registration_path,
               title: t('landing.tool_synergy_title'), desc: t('landing.tool_synergy_desc'), cta: t('landing.tool_synergy_cta') },
             { icon: 'gem',                   color: '#0ea5e9', glow: 'rgba(14,165,233,0.3)', path: new_user_registration_path,
               title: t('landing.tool_rarity_title'), desc: t('landing.tool_rarity_desc'), cta: t('landing.tool_rarity_cta') },
           ] %>
        <% tools.each_with_index do |tool, i| %>
          <div class="lp-tool-card lp-sr" data-sr="fade-up" data-sr-delay="<%= i * 80 %>"
               style="--tc:#{ tool[:color] };--tc-glow:#{ tool[:glow] };">
            <div class="lp-tool-icon"><i class="bi bi-<%= tool[:icon] %>"></i></div>
            <h3 class="lp-tool-title"><%= tool[:title] %></h3>
            <p class="lp-tool-desc"><%= tool[:desc] %></p>
            <%= link_to tool[:path], class: "lp-tool-cta" do %>
              <%= tool[:cta] %> <i class="bi bi-arrow-right ms-1"></i>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <%# ─────────────────────────────────────────────────────
      PARTY SECTION — party management showcase
  ───────────────────────────────────────────────────────── %>
  <section class="lp-section lp-section-party">
    <div class="lp-container">
      <div class="lp-party-inner">

        <%# Left: text + features %>
        <div class="lp-party-text lp-sr" data-sr="slide-left">
          <span class="lp-pill lp-pill-warning">
            <i class="bi bi-people-fill me-1"></i><%= t('landing.party_badge') %>
          </span>
          <h2 class="lp-section-title lp-gradient-title text-start mt-3 mb-3"><%= t('landing.party_title') %></h2>
          <p class="lp-section-sub text-start mb-4"><%= t('landing.party_subtitle') %></p>

          <div class="lp-party-features">
            <% [
                 { icon: 'shield-fill',       color: '#a78bfa', title: t('landing.party_feature_1_title'), desc: t('landing.party_feature_1_desc') },
                 { icon: 'stars',             color: '#fbbf24', title: t('landing.party_feature_2_title'), desc: t('landing.party_feature_2_desc') },
                 { icon: 'graph-up-arrow',    color: '#34d399', title: t('landing.party_feature_3_title'), desc: t('landing.party_feature_3_desc') },
               ].each do |pf| %>
              <div class="lp-party-feature">
                <div class="lp-party-feature-dot" style="background:<%= pf[:color] %>;box-shadow:0 0 10px <%= pf[:color] %>55;">
                  <i class="bi bi-<%= pf[:icon] %>"></i>
                </div>
                <div>
