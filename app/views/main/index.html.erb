  .lp-rune-3 { bottom: 28%; left: 10%; color: rgba(52,211,153,0.18); animation-duration: 8s; animation-delay: 2s; }
  .lp-rune-4 { bottom: 18%; right: 12%; color: rgba(251,191,36,0.18); animation-duration: 10s; animation-delay: 0.5s; }
  .lp-rune-5 { top: 52%; left: 4%;   color: rgba(248,113,113,0.16); animation-duration: 12s; animation-delay: 1.5s; }
