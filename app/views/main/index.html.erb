  .lp-num-card, .lp-tool-card { overflow: hidden; }

  /* ─────────────────────────────────────
     HERO
  ───────────────────────────────────── */
  .lp-hero {
    position: relative;
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center;
