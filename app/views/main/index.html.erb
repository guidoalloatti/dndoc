  .lp-sr[data-sr="slide-left"] { opacity: 0; transform: translateX(-50px); transition: opacity 0.65s ease, transform 0.65s ease; }
  .lp-sr[data-sr="slide-right"]{ opacity: 0; transform: translateX(50px);  transition: opacity 0.65s ease, transform 0.65s ease; }
  .lp-sr.lp-sr-visible { opacity: 1 !important; transform: none !important; }

  /* ─────────────────────────────────────
     TOOLS
  ───────────────────────────────────── */
  .lp-section-tools {
    background: var(--bs-body-bg);
    background-image: radial-gradient(rgba(99,102,241,0.06) 1px, transparent 1px);
