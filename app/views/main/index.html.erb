  <%# ── LANDING JS ── %>
  <script>
  (function() {
    'use strict';

    /* ── Helpers ── */
    function qs(sel) { return document.querySelector(sel); }
    function qsa(sel) { return document.querySelectorAll(sel); }

    function onReady(fn) {
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', fn);
      else fn();
    }

    /* ── Starfield canvas ── */
    function initStars() {
      var canvas = qs('#lp-starfield');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var stars = [];
      var W, H;

      function resize() {
        W = canvas.width  = canvas.offsetWidth;
        H = canvas.height = canvas.offsetHeight;
      }

      function makeStars() {
        stars = [];
        var count = Math.floor((W * H) / 4500);
        for (var i = 0; i < count; i++) {
          stars.push({
            x: Math.random() * W,
            y: Math.random() * H,
            r: Math.random() * 1.2 + 0.2,
            a: Math.random(),
            da: (Math.random() - 0.5) * 0.005,
            spd: Math.random() * 0.06 + 0.01
          });
        }
      }

      function draw(scrollY) {
        ctx.clearRect(0, 0, W, H);
        stars.forEach(function(s) {
          s.a += s.da;
          if (s.a <= 0 || s.a >= 1) s.da = -s.da;
          s.y += s.spd;
          if (s.y > H) { s.y = 0; s.x = Math.random() * W; }
          ctx.beginPath();
          ctx.arc(s.x, s.y - scrollY * 0.05, s.r, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(255,255,255,' + s.a + ')';
          ctx.fill();
        });
      }

      var scrollY = 0;
      var raf;
      function loop() { draw(scrollY); raf = requestAnimationFrame(loop); }
      window.addEventListener('scroll', function() { scrollY = window.pageYOffset; }, { passive: true });
      window.addEventListener('resize', function() { resize(); makeStars(); });

      resize(); makeStars(); loop();

      // Stop when hero not visible
      var hero = qs('#lp-hero');
      if (hero) {
        new IntersectionObserver(function(entries) {
          if (!entries[0].isIntersecting) { cancelAnimationFrame(raf); }
          else { loop(); }
        }, { threshold: 0 }).observe(hero);
      }
    }

    /* ── CTA sparks canvas ── */
    function initCtaSparks() {
      var canvas = qs('#lp-cta-sparks');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var particles = [];
      var W, H;

      function resize() {
        W = canvas.width  = canvas.offsetWidth;
        H = canvas.height = canvas.offsetHeight;
      }

      function spawn() {
        particles.push({
          x: Math.random() * W, y: H + 5,
          vx: (Math.random() - 0.5) * 1.2,
          vy: -(Math.random() * 1.5 + 0.5),
          r: Math.random() * 2 + 0.5,
          a: 1,
          color: ['#ffc107','#ef4444','#6366f1','#10b981'][Math.floor(Math.random()*4)]
        });
      }

      function draw() {
        ctx.clearRect(0, 0, W, H);
        if (Math.random() < 0.15) spawn();
        particles = particles.filter(function(p) {
          p.x += p.vx; p.y += p.vy; p.a -= 0.008;
          if (p.a <= 0) return false;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fillStyle = p.color;
          ctx.globalAlpha = p.a;
          ctx.fill();
          ctx.globalAlpha = 1;
          return true;
        });
        requestAnimationFrame(draw);
      }

      resize(); draw();
      window.addEventListener('resize', resize);
    }

    /* ── Mouse parallax on hero ── */
    function initMouseParallax() {
      var hero = qs('#lp-hero');
      if (!hero) return;
      var orbs = qsa('[data-depth]');
      var cx = 0, cy = 0, tx = 0, ty = 0;

      hero.addEventListener('mousemove', function(e) {
        var rect = hero.getBoundingClientRect();
        tx = (e.clientX - rect.left - rect.width / 2) / rect.width;
        ty = (e.clientY - rect.top - rect.height / 2) / rect.height;
      });

      (function lerp() {
        cx += (tx - cx) * 0.06;
        cy += (ty - cy) * 0.06;
        orbs.forEach(function(orb) {
          var d = parseFloat(orb.getAttribute('data-depth'));
          orb.style.transform = 'translate(' + (cx * d * 120) + 'px,' + (cy * d * 80) + 'px)';
        });
        requestAnimationFrame(lerp);
      })();
    }

    /* ── Scroll parallax for hero layers ── */
    function initScrollParallax() {
      var hero = qs('#lp-hero');
      if (!hero) return;
      var layers = qsa('[data-parallax]');

      window.addEventListener('scroll', function() {
        var scrollY = window.pageYOffset;
        var heroH = hero.offsetHeight;
        if (scrollY > heroH * 1.2) return;

        layers.forEach(function(layer) {
          var speed = parseFloat(layer.getAttribute('data-parallax'));
          layer.style.transform = 'translateY(' + (scrollY * speed) + 'px)';
        });

        // Fade hero content
        var content = qs('.lp-hero-content');
        if (content) {
          var fade = Math.max(0, 1 - scrollY / (heroH * 0.65));
          content.style.opacity = fade;
          content.style.transform = 'translateY(' + (scrollY * 0.12) + 'px)';
        }
      }, { passive: true });
    }

    /* ── Entrance animations on hero load ── */
    function initHeroAnims() {
      var items = qsa('.lp-anim');
      items.forEach(function(el) {
        var delay = parseInt(el.getAttribute('data-lp-delay') || '0', 10);
        el.style.opacity = '0';
        el.style.transform = 'translateY(28px)';
        setTimeout(function() {
          el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        }, delay + 120);
      });
    }

    /* ── Scroll-reveal ── */
    function initScrollReveal() {
      var els = qsa('.lp-sr');
      if (!els.length) return;

      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          var delay = parseInt(entry.target.getAttribute('data-sr-delay') || '0', 10);
          var type  = entry.target.getAttribute('data-sr') || 'fade-up';
          setTimeout(function() {
            entry.target.classList.add('lp-sr-visible');
            entry.target.setAttribute('data-sr-done', type);
          }, delay);
          observer.unobserve(entry.target);
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

      els.forEach(function(el) { observer.observe(el); });
    }

    /* ── Counter animation ── */
    function initCounters() {
      var counters = qsa('.counter');
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var target = parseInt(el.getAttribute('data-count'), 10);
          var startTime = null;
          var duration = 1800;
          (function step(ts) {
            if (!startTime) startTime = ts;
            var p = Math.min((ts - startTime) / duration, 1);
            var eased = 1 - Math.pow(1 - p, 3);
            el.textContent = Math.floor(eased * target);
            if (p < 1) requestAnimationFrame(step);
            else el.textContent = target;
          })(performance.now());
          obs.unobserve(el);
        });
      }, { threshold: 0.5 });
      counters.forEach(function(c) { obs.observe(c); });
    }

    /* ── 3D tilt on item card ── */
    function initTilt() {
      qsa('.lp-item-card').forEach(function(card) {
        card.addEventListener('mousemove', function(e) {
          var rect = card.getBoundingClientRect();
          var x = (e.clientX - rect.left) / rect.width  - 0.5;
          var y = (e.clientY - rect.top)  / rect.height - 0.5;
          card.style.transform = 'perspective(900px) rotateY(' + (x * 10) + 'deg) rotateX(' + (-y * 8) + 'deg) scale(1.02)';
        });
        card.addEventListener('mouseleave', function() {
          card.style.transform = 'perspective(900px) rotateY(0) rotateX(0) scale(1)';
        });
      });
    }

    /* ── Smooth scroll for anchor links ── */
    function initSmoothScroll() {
      qsa('a[href^="#"]').forEach(function(a) {
        a.addEventListener('click', function(e) {
          var target = document.getElementById(a.getAttribute('href').slice(1));
          if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
        });
      });
    }

    /* ── Nav: hide on scroll-down, reveal on scroll-up ── */
    function initNav() {
      var nav = qs('#lp-nav');
      if (!nav) return;

      var lastY  = window.pageYOffset;
      var hidden = false;
      var HIDE_THRESHOLD = 120;

      function update() {
        var y = window.pageYOffset;

        // Frosted glass once past top
        if (y > 40) nav.classList.add('scrolled');
        else         nav.classList.remove('scrolled');

        if (y <= HIDE_THRESHOLD) {
          if (hidden) { nav.classList.remove('lp-nav-hidden'); hidden = false; }
        } else if (y > lastY && !hidden) {
          nav.classList.add('lp-nav-hidden'); hidden = true;
        } else if (y < lastY && hidden) {
          nav.classList.remove('lp-nav-hidden'); hidden = false;
        }

        lastY = y;
      }

      window.addEventListener('scroll', update, { passive: true });
      update();
    }

    /* ── Cursor spotlight in hero ── */
    function initSpotlight() {
      var hero = qs('#lp-hero');
      var spot = qs('#lp-spotlight');
      if (!hero || !spot) return;
      var sx = -999, sy = -999, tx = -999, ty = -999;
      hero.addEventListener('mousemove', function(e) {
        var r = hero.getBoundingClientRect();
        tx = e.clientX - r.left;
        ty = e.clientY - r.top;
      });
      hero.addEventListener('mouseleave', function() { tx = -999; ty = -999; });
      (function loop() {
        sx += (tx - sx) * 0.08;
        sy += (ty - sy) * 0.08;
        if (tx > 0) {
          spot.style.left = sx + 'px';
          spot.style.top  = sy + 'px';
          spot.style.opacity = '1';
        } else {
          spot.style.opacity = '0';
        }
        requestAnimationFrame(loop);
      })();
    }

    /* ── Rotating words in hero title ── */
    function initWordRotator() {
      var words = qsa('#lp-rotate-wrap .lp-rw');
      if (!words.length) return;
      var current = 0;
      setInterval(function() {
        words[current].classList.remove('lp-rw-active');
        words[current].classList.add('lp-rw-exit');
        current = (current + 1) % words.length;
        words[current].classList.add('lp-rw-enter');
        setTimeout(function() {
          words[current].classList.remove('lp-rw-enter');
          words[current].classList.add('lp-rw-active');
          // clean up exit
          words.forEach(function(w) { if (w !== words[current]) { w.classList.remove('lp-rw-exit'); } });
        }, 50);
      }, 2400);
    }

    /* ── Magnetic buttons ── */
    function initMagnetic() {
      qsa('.lp-btn-primary, .lp-nav-signup').forEach(function(btn) {
        btn.addEventListener('mousemove', function(e) {
          var r = btn.getBoundingClientRect();
          var x = (e.clientX - r.left - r.width  / 2) * 0.22;
          var y = (e.clientY - r.top  - r.height / 2) * 0.22;
          btn.style.transform = 'translate(' + x + 'px,' + y + 'px) translateY(-2px)';
        });
        btn.addEventListener('mouseleave', function() {
          btn.style.transform = '';
        });
      });
    }

    /* ── Card hover sparkle burst ── */
    function initSparkle() {
      qsa('.lp-num-card, .lp-tool-card').forEach(function(card) {
        card.addEventListener('mouseenter', function(e) {
          var r = card.getBoundingClientRect();
          for (var i = 0; i < 6; i++) {
            (function(i) {
              setTimeout(function() {
                var sp = document.createElement('span');
                sp.className = 'lp-sparkle';
                sp.style.left = (20 + Math.random() * (r.width - 40)) + 'px';
                sp.style.top  = (20 + Math.random() * (r.height - 40)) + 'px';
                sp.style.setProperty('--sc', getComputedStyle(card).getPropertyValue('--nc') || getComputedStyle(card).getPropertyValue('--tc') || '#818cf8');
                card.appendChild(sp);
                setTimeout(function() { sp.remove(); }, 700);
              }, i * 60);
            })(i);
          }
        });
      });
    }

    /* ── Run all ── */
    function init() {
      initStars();
      initCtaSparks();
      initMouseParallax();
      initScrollParallax();
      initHeroAnims();
      initScrollReveal();
      initCounters();
      initTilt();
      initSmoothScroll();
      initNav();
      initSpotlight();
      initWordRotator();
      initMagnetic();
      initSparkle();
    }

    onReady(init);
    document.addEventListener('turbo:load', init);
  })();
  </script>

