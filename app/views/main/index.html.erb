  .lp-stat-label { font-size: 0.7rem; color: rgba(255,255,255,0.45); text-transform: uppercase; letter-spacing: .08em; font-weight: 600; }

  /* ─────────────────────────────────────
     BY THE NUMBERS
  ───────────────────────────────────── */
  .lp-section-numbers {
    background: var(--bs-body-bg);
    background-image: radial-gradient(rgba(99,102,241,0.07) 1px, transparent 1px);
    background-size: 28px 28px;
  }
  .lp-numbers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 20px;
  }
  .lp-num-card {
    padding: 28px 20px 24px;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--nc) 20%, transparent);
    background: var(--nc-bg);
    text-align: center;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    cursor: default;
  }
  .lp-num-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 36px color-mix(in srgb, var(--nc) 20%, transparent);
  }
  .lp-num-card-highlight {
    border-color: color-mix(in srgb, var(--nc) 40%, transparent);
    background: color-mix(in srgb, var(--nc) 12%, var(--bs-body-bg));
    animation: cardPulse 3s ease-in-out infinite;
  }
  @keyframes cardPulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--nc) 20%, transparent); }
    50%       { box-shadow: 0 0 0 8px color-mix(in srgb, var(--nc) 0%, transparent); }
