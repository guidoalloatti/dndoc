<input type="hidden" id="item_id" value="<%= item.persisted? ? item.id : 0 %>">

<%= form_with(model: @item, local: true) do |form| %>

  <%# ══ Row 1: Name + Description + Lore ══ %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2 px-3">
      <div class="form-top-row">

        <%# Left: Name + Lore stacked %>
        <div class="form-top-left">
          <div class="mb-2">
            <label class="form-label-compact mb-1"><i class="bi bi-tag me-1"></i><%= t('shared.name') %></label>
            <div class="input-group input-group-sm">
              <%= form.text_field :name, class: 'form-control', placeholder: t('items.name_placeholder'), id: 'item_name' %>
              <button id="generateNameBtn" class="btn btn-outline-primary" type="button" title="<%= t('items.generate') %>">
                <i class="bi bi-magic"></i>
              </button>
            </div>
          </div>
          <div>
            <label class="form-label-compact mb-1"><i class="bi bi-book me-1"></i><%= t('items.lore_setting') %></label>
            <div id="lorePicker" class="lore-radio-group lore-radio-group-vertical">
              <label class="lore-radio-btn active">
                <input type="radio" name="lore_pick" value="faerun" checked class="lore-btn" data-lore="faerun">
                <i class="bi bi-globe-americas"></i><%= t('items.lore_faerun') %>
              </label>
              <label class="lore-radio-btn">
                <input type="radio" name="lore_pick" value="middle_earth" class="lore-btn" data-lore="middle_earth">
                <i class="bi bi-tree"></i><%= t('items.lore_middle_earth') %>
              </label>
            </div>
          </div>
        </div>

        <%# Right: Description %>
        <div class="form-top-desc">
          <div class="d-flex align-items-center justify-content-between mb-1">
            <label class="form-label-compact mb-0"><i class="bi bi-file-text me-1"></i><%= t('items.description') %></label>
            <div class="d-flex gap-1">
              <button id="rewriteDescBtn" class="btn btn-xs btn-outline-primary" type="button"
                      data-rewrite-label="<%= t('items.rewrite_desc') %>">
                <i class="bi bi-arrow-repeat me-1"></i><%= t('items.rewrite_desc') %>
              </button>
              <button id="lockDescBtn" class="btn btn-xs btn-outline-secondary" type="button" data-locked="false"
                      data-locked-label="<%= t('items.desc_locked') %>"
                      data-unlocked-label="<%= t('items.desc_unlocked') %>">
                <i class="bi bi-unlock me-1" id="lockDescIcon"></i><span id="lockDescLabel"><%= t('items.desc_unlocked') %></span>
              </button>
            </div>
          </div>
          <textarea id="item_description_display" class="form-control form-control-sm desc-textarea" rows="5"
                    placeholder="<%= t('items.desc_placeholder') %>"><%= item.persisted? ? item.description : "" %></textarea>
          <input type="hidden" id="item_description_locked" value="<%= item.persisted? ? 'true' : 'false' %>">
        </div>

      </div>
    </div>
  </div>

  <%# ══ Row 2: Category + Weapon type ══ %>
  <div class="row g-3 mb-4">
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body py-2 px-3">
          <div class="form-label-compact mb-2"><i class="bi bi-grid-3x3-gap me-1"></i><%= t('items.category') %></div>
          <div class="d-flex flex-wrap gap-1" id="categoryPicker">
            <% categories.each do |cat| %>
              <button type="button"
                      class="btn btn-outline-secondary btn-xs category-btn d-flex align-items-center gap-1"
                      data-id="<%= cat.id %>"
                      data-name="<%= cat.name %>"
                      title="<%= cat.name %>">
                <% if cat.image.attached? %>
                  <%= image_tag cat.image, style: "width:14px;height:14px;object-fit:cover;border-radius:3px;flex-shrink:0;" %>
                <% else %>
                  <i class="bi bi-<%= category_icon(cat.name) %>"></i>
                <% end %>
                <%= cat.name %>
              </button>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body py-2 px-3">
          <div id="addWeapons" style="display:none;">
            <div class="form-label-compact mb-2"><i class="bi bi-hammer me-1"></i><%= t('items.weapon_type') %></div>
            <div class="d-flex flex-wrap gap-1" id="weaponPicker">
              <% weapons.each_with_index do |weapon, idx| %>
                <button type="button"
                        class="btn btn-xs weapon-btn <%= idx == 0 ? 'active btn-primary' : 'btn-outline-secondary' %>"
                        data-id="<%= weapon.id %>"
                        data-name="<%= weapon.name %>"
                        data-damage="<%= weapon.damage %>"
                        data-cost="<%= weapon.cost %>"
                        title="<%= weapon.damage %> · <%= weapon.cost %>">
                  <i class="bi bi-<%= weapon_icon(weapon.name) %> me-1"></i><%= weapon.name %>
                </button>
              <% end %>
            </div>
            <div id="weaponDetails" class="mt-2 text-muted small" style="display:none;">
              <i class="bi bi-bullseye me-1"></i><span id="weaponDamage"></span>
              <span class="mx-2 opacity-50">·</span>
              <i class="bi bi-coin me-1"></i><span id="weaponCost"></span>
            </div>
          </div>
          <div id="noWeaponHint" class="text-muted small fst-italic py-2">
            <i class="bi bi-arrow-left me-1 opacity-50"></i><%= t('items.select_weapon_category') %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# ══ Row 3: Origin + Rarity + Power (single compact row) ══ %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2 px-3">
      <div class="rarity-power-row">

        <%# Origin %>
        <div class="rarity-power-col">
          <div class="form-label-compact mb-1"><i class="bi bi-compass me-1"></i><%= t('items.origin') %></div>
          <% origin_classes = { 'Divino' => 'btn-outline-warning', 'Elfico' => 'btn-outline-success', 'Enano' => 'btn-outline-danger', 'Humano' => 'btn-outline-primary', 'Desconocido' => 'btn-outline-secondary' } %>
          <% origin_active_classes = { 'Divino' => 'btn-warning', 'Elfico' => 'btn-success', 'Enano' => 'btn-danger', 'Humano' => 'btn-primary', 'Desconocido' => 'btn-secondary' } %>
          <div id="originPicker" class="d-flex flex-wrap gap-1">
            <% Item::ORIGINS.each do |origin| %>
              <% is_active = (item.persisted? ? item.origin.to_s : 'Desconocido') == origin %>
              <button type="button"
                      class="btn btn-xs origin-btn <%= is_active ? "active #{origin_active_classes[origin]}" : origin_classes[origin] %>"
                      data-origin="<%= origin %>"
                      style="<%= origin == 'Divino' ? 'display:none;' : '' %>">
                <i class="bi bi-<%= origin_icon(origin) %> me-1"></i><%= t("items.origin_#{origin.downcase}") %>
              </button>
            <% end %>
          </div>
          <input type="hidden" id="item_origin" name="item_origin" value="<%= item.persisted? ? item.origin.to_s : 'Desconocido' %>">
        </div>

        <div class="rarity-power-sep"></div>

        <%# Rarity %>
        <div class="rarity-power-col">
          <div class="form-label-compact mb-1"><i class="bi bi-stars me-1"></i><%= t('items.rarity') %></div>
          <div class="d-flex flex-wrap gap-1" id="rarityPicker"><%# JS %></div>
        </div>

        <div class="rarity-power-sep"></div>

        <%# Power %>
        <div class="rarity-power-col">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <div class="form-label-compact"><i class="bi bi-lightning-charge me-1"></i><%= t('items.power') %></div>
            <span id="powerUsageText" class="form-label-compact fw-bold" style="letter-spacing:0;">0 / 10</span>
          </div>
          <%= form.hidden_field :power, id: 'item_power', value: item.persisted? ? item.power : 10 %>
          <div class="d-flex gap-1 flex-wrap align-items-center" id="powerPicker">
            <% (0..10).each do |p| %>
              <button type="button" class="power-btn <%= p == 10 ? 'active' : '' %>" data-power="<%= p %>"><%= p %></button>
            <% end %>
          </div>
          <input type="range" id="powerSlider" min="0" max="10" value="10" step="1" class="power-slider mt-2">
        </div>

      </div>
    </div>
  </div>

  <%# ══ Effects ══ %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2 px-3">

      <%# Header %>
      <div class="d-flex align-items-center justify-content-between mb-2">
        <div class="form-label-compact mb-0"><i class="bi bi-magic me-1"></i><span id="effectsLabel"><%= t('items.effects') %></span></div>
        <div class="d-flex align-items-center gap-2">
          <div id="powerWarning" style="display:none;">
            <span class="badge bg-danger" style="font-size:0.65rem;"><i class="bi bi-exclamation-triangle-fill me-1"></i><span id="powerWarningText"></span></span>
          </div>
          <button id="resetEffects" class="btn btn-link p-0 text-danger" style="font-size:0.7rem;" type="button">
            <i class="bi bi-arrow-counterclockwise me-1"></i><%= t('items.reset') %>
          </button>
        </div>
      </div>

      <%# Two-panel layout %>
      <div class="effects-panels">

        <%# Left panel: selected effects %>
        <div class="effects-panel effects-panel-left">
          <div class="effects-panel-title">
            <i class="bi bi-check2-circle me-1"></i><%= t('items.effects_in_use') %>
            <span class="ms-auto fw-bold" id="powerUsageText">0 / 10</span>
          </div>
          <div id="selectedEffects" class="selected-effects-list"></div>
          <div id="noEffectsHint" class="effects-empty-hint">
            <i class="bi bi-arrow-right me-1 opacity-50"></i><%= t('items.effects_hint') %>
          </div>
        </div>

        <%# Right panel: available effects %>
        <div class="effects-panel effects-panel-right">
          <div class="effects-panel-title">
            <i class="bi bi-collection me-1"></i><%= t('items.effects_available') %>
            <div class="ms-auto d-flex gap-1">
              <select id="powerFilter" class="eff-filter-select">
                <option value=""><%= t('items.power') %> —</option>
                <option value="1">≤ 1</option>
                <option value="2">≤ 2</option>
                <option value="3">≤ 3</option>
                <option value="4">≤ 4</option>
                <option value="5+">≥ 5</option>
              </select>
              <select id="effectSort" class="eff-filter-select">
                <option value="name">A–Z</option>
                <option value="power_asc"><%= t('items.power') %> ↑</option>
                <option value="power_desc"><%= t('items.power') %> ↓</option>
                <option value="group"><%= t('items.group') %></option>
              </select>
            </div>
          </div>
          <div class="d-flex align-items-center gap-1 mb-1">
            <div id="effectGroupTabs" class="d-flex flex-wrap gap-1 flex-grow-1"></div>
            <div id="effectFlash" class="effect-flash"></div>
          </div>
          <div id="availableEffects" class="effect-grid"></div>
        </div>

      </div>
    </div>
  </div>

  <%# ══ Action bar ══ %>
  <div class="create-action-bar">
    <div class="d-flex justify-content-center">
      <button id="<%= action == "Create" ? "createItem" : "updateItem" %>" class="btn btn-lg btn-outline-primary disabled px-5 shadow" type="button">
        <i class="bi bi-<%= action == "Create" ? "hammer" : "check-lg" %> me-2"></i>
        <%= action == "Create" ? t('items.create_item') : t('items.update_item') %>
      </button>
    </div>
  </div>
<% end %>

<%# ── Forge Animation Overlay ── %>
<div id="forgeOverlay" class="forge-overlay" style="display:none;">
  <div class="forge-content text-center">
    <div class="forge-anvil mb-3">
      <i class="bi bi-hammer forge-hammer"></i>
      <div class="forge-sparks">
        <span class="spark"></span><span class="spark"></span><span class="spark"></span>
        <span class="spark"></span><span class="spark"></span><span class="spark"></span>
      </div>
      <div class="forge-fire">
        <span class="flame flame-1"></span>
        <span class="flame flame-2"></span>
        <span class="flame flame-3"></span>
      </div>
    </div>
    <h5 class="text-white fw-bold" id="forgeTitle"><%= action == "Create" ? t('items.creating') : t('items.updating') %></h5>
    <p class="text-white-50 small" id="forgeDesc"><%= action == "Create" ? t('items.creating_desc') : t('items.updating_desc') %></p>
  </div>
</div>
