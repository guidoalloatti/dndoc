<% rarity = @item.rarity.name %>
<% rarity_class = rarity_css_class(rarity) %>

<div class="container mt-4" style="max-width: 680px;">

  <%# ── Top actions ── %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <%= link_to items_path, class: "btn btn-sm btn-outline-secondary" do %>
      <i class="bi bi-arrow-left me-1"></i><%= t('shared.back') %>
    <% end %>
    <div class="d-flex gap-1">
      <%= link_to edit_item_path(@item), class: "btn btn-sm btn-outline-primary" do %>
        <i class="bi bi-pencil me-1"></i><%= t('shared.edit') %>
      <% end %>
      <%= button_to item_path(@item), method: :delete, data: { turbo_confirm: t('shared.confirm_delete') }, class: "btn btn-sm btn-outline-danger" do %>
        <i class="bi bi-trash3"></i>
      <% end %>
    </div>
  </div>

  <%# ══════════════════════════════════════ %>
  <%# ── HERO CARD ── %>
  <%# ══════════════════════════════════════ %>
  <div class="card border-0 shadow-sm mb-3 item-show-hero rarity-<%= rarity_class %>" id="itemHeroCard">

    <%# Item image banner — item's own image first, then category fallback %>
    <div class="item-show-banner" id="itemHeroBanner">
      <% if @item.image.attached? %>
        <%= image_tag @item.image, class: "item-show-banner-img", id: "itemHeroImg",
            onload: "detectItemImgOrientation(this)" %>
      <% else %>
        <%= category_image_or_placeholder(@item.category, size: 96, class: "item-show-banner-img") %>
      <% end %>
      <div class="item-show-banner-overlay"></div>
      <%# Power pill on top-right of banner %>
      <div class="item-show-banner-power">
        <span class="badge rounded-pill <%= power_badge_class(@item.power) %>"><%= @item.power %></span>
        <div style="font-size:0.5rem;text-transform:uppercase;letter-spacing:0.06em;opacity:0.7;margin-top:2px;"><%= t('items.power') %></div>
      </div>
    </div>

    <div class="card-body pt-3">
      <%# Name + badges %>
      <h4 class="fw-bold mb-1"><%= @item.name %></h4>
      <div class="d-flex align-items-center gap-1 flex-wrap mb-3">
        <span class="badge <%= rarity_badge_class(rarity) %>" style="font-size:0.68rem;"><i class="bi bi-star-fill me-1"></i><%= rarity %></span>
        <span class="badge bg-body-secondary text-body" style="font-size:0.68rem;"><i class="bi bi-<%= category_icon(@item.category.name) %> me-1"></i><%= @item.category.name %></span>
        <% if @item.weapon_name.present? %>
          <span class="badge bg-body-secondary text-body" style="font-size:0.68rem;"><i class="bi bi-<%= weapon_icon(@item.weapon_name) %> me-1"></i><%= @item.weapon_name %></span>
        <% end %>
        <% if @item.origin.present? && @item.origin != "Desconocido" %>
          <span class="badge bg-body-secondary text-body" style="font-size:0.68rem;"><i class="bi bi-<%= origin_icon(@item.origin) %> me-1"></i><%= t("items.origin_#{@item.origin.downcase}") %></span>
        <% end %>
        <% if @item.requires_attunement %>
          <span class="badge bg-warning text-dark" style="font-size:0.68rem;"><i class="bi bi-link-45deg me-1"></i><%= t('items.attunement_required') %></span>
        <% end %>
      </div>

      <%# Description — truncated with expand %>
      <% if @item.description.present? %>
        <div class="item-desc-wrap mb-3" id="itemDescWrap">
          <p class="item-desc-text mb-0 small" id="itemDescText" style="line-height:1.65;color:var(--bs-secondary-color);">
            <%= @item.description %>
          </p>
        </div>
        <% if @item.description.length > 280 %>
          <button class="btn btn-link p-0 item-desc-toggle" id="itemDescToggle" style="font-size:0.72rem;">
            <i class="bi bi-chevron-down me-1" id="itemDescToggleIcon"></i><span id="itemDescToggleLabel"><%= t('items.desc_show_more') %></span>
          </button>
        <% end %>
      <% end %>

      <%# Inline stats row %>
      <div class="d-flex gap-3 pt-3 border-top flex-wrap">
        <div class="d-flex align-items-center gap-1">
          <i class="bi bi-coin text-warning" style="font-size:0.75rem;"></i>
          <span class="fw-bold small"><%= number_with_delimiter(@item.price) %></span>
          <span class="text-muted" style="font-size:0.65rem;"><%= t('items.gold_pieces') %></span>
        </div>
        <div class="d-flex align-items-center gap-1">
          <i class="bi bi-feather text-muted" style="font-size:0.75rem;"></i>
          <span class="fw-bold small"><%= @item.weight %></span>
          <span class="text-muted" style="font-size:0.65rem;">lbs</span>
        </div>
        <% if @item.item_type.present? && @item.item_type != @item.category.name %>
          <div class="d-flex align-items-center gap-1">
            <i class="bi bi-tag text-muted" style="font-size:0.75rem;"></i>
            <span class="fw-bold small"><%= @item.item_type %></span>
          </div>
        <% end %>
        <% if @item.lore.present? %>
          <div class="d-flex align-items-center gap-1 text-muted">
            <i class="bi bi-book" style="font-size:0.75rem;"></i>
            <span class="small" style="font-size:0.65rem;"><%= @item.lore == "middle_earth" ? t('items.lore_middle_earth') : t('items.lore_faerun') %></span>
          </div>
        <% end %>
        <div class="ms-auto d-flex align-items-center gap-1 text-muted" style="font-size:0.6rem;">
          <i class="bi bi-calendar3"></i>
          <%= @item.created_at.strftime("%b %d, %Y") %>
        </div>
      </div>
    </div>
  </div>

  <%# ══════════════════════════════════════ %>
  <%# ── EFFECTS ── %>
  <%# ══════════════════════════════════════ %>
  <% if @item.effects.any? %>
    <div class="d-flex align-items-center justify-content-between mb-2">
      <h6 class="text-muted text-uppercase small fw-semibold mb-0">
        <i class="bi bi-magic me-1"></i> <%= t('items.item_effects') %>
        <span class="badge bg-primary rounded-pill ms-1" style="font-size:0.55rem;"><%= @item.effects.size %></span>
      </h6>
      <% used = @item.effects.sum(&:power_level) %>
      <span class="text-muted" style="font-size:0.65rem;">
        <i class="bi bi-lightning-charge me-1"></i><%= used %> / <%= @item.power %> <%= t('items.power_used').downcase %>
      </span>
    </div>

    <%# Power usage bar %>
    <div class="progress mb-3" style="height:3px;border-radius:2px;">
      <% pct = @item.power > 0 ? [(used.to_f / @item.power * 100), 100].min : 0 %>
      <div class="progress-bar bg-<%= pct >= 100 ? 'success' : 'primary' %>" style="width:<%= pct %>%;"></div>
    </div>

    <%# Effect cards %>
    <div class="d-flex flex-column gap-2 mb-3">
      <% @item.effects.each do |effect| %>
        <% color = effect_type_color(effect.effect_type) %>
        <div class="item-effect-row p-2" style="border-left:3px solid var(--bs-<%= color %>) !important;">
          <div class="d-flex align-items-start gap-2">
            <div class="effect-type-icon bg-<%= color %> bg-opacity-10 text-<%= color %>">
              <i class="bi bi-<%= effect_type_icon(effect.effect_type) %>"></i>
            </div>
            <div class="flex-grow-1" style="min-width:0;">
              <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-1">
                  <span class="fw-semibold small"><%= effect.translated_name %></span>
                  <span class="badge bg-<%= color %> bg-opacity-10 text-<%= color %>" style="font-size:0.55rem;"><%= effect.effect_type %></span>
                </div>
                <span class="badge bg-<%= color %> rounded-pill" style="font-size:0.7rem;min-width:22px;"><%= effect.power_level %></span>
              </div>
              <% if effect.translated_description.present? %>
                <p class="mb-0 mt-1 text-muted" style="font-size:0.72rem;line-height:1.4;"><%= effect.translated_description %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body py-3 text-center">
        <i class="bi bi-magic text-muted" style="font-size:1.5rem;"></i>
        <p class="text-muted small mb-0 mt-1"><%= t('items.no_effects') %></p>
      </div>
    </div>
  <% end %>

</div>

<script>
function detectItemImgOrientation(img) {
  // If image is already cached and loaded when this runs
  if (img.complete) applyItemImgOrientation(img);
}
function applyItemImgOrientation(img) {
  const hero = document.getElementById('itemHeroCard');
  if (!hero) return;
  const isPortrait = img.naturalHeight > img.naturalWidth * 1.15;
  if (isPortrait) {
    hero.classList.add('item-hero-portrait');
  } else {
    hero.classList.remove('item-hero-portrait');
  }
}
// Also run on DOMContentLoaded in case onload already fired before script parsed
(function() {
  const img = document.getElementById('itemHeroImg');
  if (img && img.complete && img.naturalWidth > 0) applyItemImgOrientation(img);
  if (img) img.addEventListener('load', function() { applyItemImgOrientation(img); });
})();
</script>

<script>
(function() {
  const wrap   = document.getElementById('itemDescWrap');
  const toggle = document.getElementById('itemDescToggle');
  if (!toggle || !wrap) return;
  let expanded = false;
  wrap.classList.add('item-desc-collapsed');
  toggle.addEventListener('click', function() {
    expanded = !expanded;
    wrap.classList.toggle('item-desc-collapsed', !expanded);
    document.getElementById('itemDescToggleIcon').className = expanded ? 'bi bi-chevron-up me-1' : 'bi bi-chevron-down me-1';
    document.getElementById('itemDescToggleLabel').textContent = expanded
      ? '<%= j t("items.desc_show_less") %>'
      : '<%= j t("items.desc_show_more") %>';
  });
})();
</script>
