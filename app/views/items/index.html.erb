<div class="container mt-4">
  <%# ── Header row ── %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0 fw-bold">
      <i class="bi bi-box-seam text-primary me-1"></i> <%= t('items.title') %>
      <span class="badge bg-primary rounded-pill ms-2 fs-6"><%= @pagy.count %></span>
    </h4>
    <div class="d-flex gap-2">
      <%= link_to create_random_items_path, class: "btn btn-sm btn-outline-primary" do %>
        <i class="bi bi-shuffle me-1"></i><%= t('items.random') %>
      <% end %>
      <%= link_to new_item_path, class: "btn btn-sm btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i><%= t('items.new') %>
      <% end %>
    </div>
  </div>

  <%# ── Filters bar ── %>
  <% has_filters = params[:q].present? || params[:category_id].present? || params[:rarity_id].present? || params[:attunement].present? %>
  <%= form_with url: items_path, method: :get, local: true, id: "items-filter-form" do %>
    <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
    <%= hidden_field_tag :dir, params[:dir] if params[:dir].present? %>
    <%= hidden_field_tag :per_page, params[:per_page] if params[:per_page].present? %>

    <div class="items-toolbar d-flex align-items-center border rounded mb-3">
      <i class="bi bi-search text-muted px-2"></i>
      <%= text_field_tag :q, params[:q],
        class: "items-toolbar-input flex-grow-1",
        placeholder: t('items.search_placeholder'),
        id: "items-search",
        autocomplete: "off" %>

      <span class="items-toolbar-sep"></span>

      <%= select_tag :category_id,
        options_from_collection_for_select(@categories, :id, :name, params[:category_id]),
        include_blank: t('items.all_categories'),
        class: "items-toolbar-select",
        onchange: "this.form.requestSubmit()" %>

      <span class="items-toolbar-sep"></span>

      <%= select_tag :rarity_id,
        options_from_collection_for_select(@rarities, :id, :name, params[:rarity_id]),
        include_blank: t('items.all_rarities'),
        class: "items-toolbar-select",
        onchange: "this.form.requestSubmit()" %>

      <span class="items-toolbar-sep"></span>

      <%= select_tag :attunement,
        options_for_select([[t('items.attunement_yes'), "true"], [t('items.attunement_no'), "false"]], params[:attunement]),
        include_blank: t('items.all_attunement'),
        class: "items-toolbar-select",
        onchange: "this.form.requestSubmit()" %>

      <% if has_filters %>
        <span class="items-toolbar-sep"></span>
        <%= link_to items_path(sort: params[:sort], dir: params[:dir], per_page: params[:per_page]), class: "items-toolbar-clear text-muted px-2", title: t('items.clear') do %>
          <i class="bi bi-x-lg"></i>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# ── Sort bar ── %>
  <div class="d-flex align-items-center gap-3 mb-2">
    <span class="text-muted small fw-semibold text-uppercase" style="font-size: 0.65rem;"><%= t('items.filter') %>:</span>
    <span style="font-size: 0.72rem;"><%= sort_link(:name, t('shared.name')) %></span>
    <span style="font-size: 0.72rem;"><%= sort_link(:rarity, t('items.rarity')) %></span>
    <span style="font-size: 0.72rem;"><%= sort_link(:price, t('items.price')) %></span>
    <span style="font-size: 0.72rem;"><%= sort_link(:power, t('items.power')) %></span>
  </div>

  <%# ── Card Grid ── %>
  <% if @items.any? %>
    <div class="row g-2">
      <% @items.each do |item| %>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="index-card rarity-<%= rarity_css_class(item.rarity.name) %>">
            <% if item.image.attached? %>
              <div class="index-card-img-strip">
                <%= image_tag item.image, alt: item.name %>
              </div>
            <% end %>
            <div class="d-flex justify-content-between align-items-start">
              <div class="flex-grow-1 min-width-0">
                <div class="d-flex align-items-center gap-1 mb-1">
                  <i class="bi bi-<%= category_icon(item.category.name) %> text-muted" style="font-size: 0.7rem;"></i>
                  <span class="card-title text-truncate"><%= link_to item.name, item_path(item), class: "text-decoration-none text-body" %></span>
                </div>
                <div class="d-flex align-items-center gap-1 flex-wrap">
                  <span class="badge <%= rarity_badge_class(item.rarity.name) %>" style="font-size: 0.6rem;"><%= item.rarity.name %></span>
                  <span class="badge bg-body-secondary text-body" style="font-size: 0.6rem;"><%= item.category.name %></span>
                  <% if item.requires_attunement %>
                    <i class="bi bi-link-45deg text-warning" style="font-size: 0.7rem;" title="<%= t('items.requires_attunement') %>"></i>
                  <% end %>
                </div>
              </div>
              <div class="card-actions">
                <%= link_to edit_item_path(item), class: "action-icon text-secondary", title: t('shared.edit') do %><i class="bi bi-pencil"></i><% end %>
                <%= button_to item_path(item), method: :delete, data: { turbo_confirm: t('shared.confirm_delete') }, class: "action-icon text-danger", title: t('shared.delete') do %><i class="bi bi-trash3"></i><% end %>
              </div>
            </div>
            <div class="card-stats">
              <span class="stat-item"><i class="bi bi-lightning-charge"></i> <%= item.power %></span>
              <span class="stat-item">
                <div class="power-bar-mini">
                  <div class="fill" style="width: <%= item.power * 10 %>%; background: <%= power_bar_color(item.power) %>;"></div>
                </div>
              </span>
              <span class="stat-item"><i class="bi bi-coin"></i> <%= number_with_delimiter(item.price) %></span>
              <span class="stat-item"><i class="bi bi-feather"></i> <%= item.weight %></span>
            </div>
            <% if item.effects.any? %>
              <div class="d-flex flex-wrap gap-1 mt-1">
                <% item.effects.limit(4).each do |effect| %>
                  <span class="badge bg-body-secondary text-body" style="font-size: 0.58rem;"><%= effect.translated_name %></span>
                <% end %>
                <% if item.effects.size > 4 %>
                  <span class="badge bg-body-secondary text-body" style="font-size: 0.58rem;">+<%= item.effects.size - 4 %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── Pagination ── %>
    <nav class="d-flex align-items-center justify-content-between mt-3 mb-4">
      <div class="d-flex align-items-center gap-2">
        <small class="text-muted">
          <%= t('items.showing', from: @pagy.from, to: @pagy.to, count: @pagy.count) %>
        </small>
        <span class="text-muted small">·</span>
        <div class="d-flex align-items-center gap-1">
          <% [20, 50, 100].each do |n| %>
            <% active = (@pagy.limit == n) %>
            <%= link_to n,
              items_path(request.params.except("controller", "action").merge(per_page: n, page: nil)),
              class: "btn btn-outline-secondary py-0 px-1 #{'active' if active}",
              style: "font-size: 0.7rem;" %>
          <% end %>
          <span class="text-muted" style="font-size: 0.7rem;"><%= t('items.per_page') %></span>
        </div>
      </div>
      <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
    </nav>
  <% else %>
    <div class="text-center py-5">
      <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
      <p class="text-muted mt-2"><%= t('shared.no_records') %></p>
      <%= link_to new_item_path, class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i><%= t('items.new') %>
      <% end %>
    </div>
  <% end %>
</div>

<script>
  function initItemsSearch() {
    var searchInput = document.getElementById("items-search");
    var form = document.getElementById("items-filter-form");
    if (!searchInput || !form || searchInput.dataset.bound) return;

    searchInput.dataset.bound = "true";
    var debounceTimer;

    searchInput.addEventListener("keyup", function() {
      clearTimeout(debounceTimer);
      var value = searchInput.value.trim();

      debounceTimer = setTimeout(function() {
        if (value.length >= 3 || value.length === 0) {
          form.requestSubmit();
        }
      }, 300);
    });
  }

  document.addEventListener("DOMContentLoaded", initItemsSearch);
  document.addEventListener("turbo:load", initItemsSearch);
</script>
