<%= form_with model: party, class: "needs-validation" do |f| %>
  <% if party.errors.any? %>
    <div class="alert alert-danger">
      <% party.errors.full_messages.each do |msg| %>
        <div><i class="bi bi-exclamation-circle me-1"></i><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <%# ── Party Details ── %>
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
      <%# Image %>
      <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
        <div class="d-flex align-items-center justify-content-center rounded-3 bg-primary bg-opacity-10 flex-shrink-0 overflow-hidden"
             style="width:80px; height:80px;">
          <% if party.has_image? %>
            <%= image_tag party.image, style: "width:100%; height:100%; object-fit:cover; border-radius:0.5rem;", alt: "" %>
          <% else %>
            <i class="bi bi-shield-fill text-primary" style="font-size:2rem;"></i>
          <% end %>
        </div>
        <div class="flex-grow-1">
          <%= f.label :image, t("parties.image"), class: "form-label fw-semibold small text-muted text-uppercase mb-1" %>
          <%= f.file_field :image, class: "form-control form-control-sm", accept: "image/jpeg,image/png,image/gif,image/webp" %>
          <div class="form-text" style="font-size:0.7rem;"><%= t("profiles.avatar_hint") %></div>
        </div>
      </div>

      <%# Name %>
      <%= f.label :name, t("parties.name"), class: "form-label fw-semibold small text-muted text-uppercase" %>
      <%= f.text_field :name,
            class: "form-control",
            placeholder: t("parties.name_placeholder"),
            required: true %>
    </div>
  </div>

  <%# ── Characters ── %>
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h6 class="fw-semibold small text-muted text-uppercase mb-0">
          <i class="bi bi-people me-1"></i><%= t("parties.characters") %>
        </h6>
        <button type="button" id="addCharacterBtn" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-plus-lg me-1"></i><%= t("parties.add_character") %>
        </button>
      </div>

      <div id="charactersList">
        <%= f.fields_for :characters do |cf| %>
          <%= render "character_fields", f: cf, character_classes: character_classes %>
        <% end %>
      </div>

      <div id="noCharactersMsg" class="text-center text-muted small py-3" style="<%= party.characters.any? ? 'display:none;' : '' %>">
        <i class="bi bi-person-plus opacity-50 me-1"></i><%= t("parties.no_characters_yet") %>
      </div>
    </div>
  </div>

  <%# ── Actions ── %>
  <div class="d-flex gap-2">
    <%= f.submit t("parties.save"), class: "btn btn-primary px-4" %>
    <%= link_to t("shared.cancel"), parties_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<%# ── Template for new character rows (JS cloning) ── %>
<template id="characterFieldTemplate">
  <div class="character-row d-flex align-items-center gap-2 p-2 mb-1 rounded border bg-body-tertiary">
    <input type="hidden" name="party[characters_attributes][CHAR_IDX][_destroy]" value="false" class="char-destroy-field">

    <button type="button" class="btn btn-danger btn-sm remove-char-btn flex-shrink-0 d-flex align-items-center justify-content-center"
            style="width:34px; height:34px; padding:0; cursor:pointer; border-radius:6px;">
      <i class="bi bi-trash3-fill" style="font-size:0.85rem;"></i>
    </button>

    <div style="min-width:100px; flex:1.2;">
      <input type="text" name="party[characters_attributes][CHAR_IDX][name]"
             class="form-control form-control-sm" placeholder="<%= t('parties.char_name_placeholder') %>">
    </div>

    <div style="min-width:110px; flex:1.1;">
      <select name="party[characters_attributes][CHAR_IDX][race]" class="form-select form-select-sm">
        <option value=""><%= t('party_rewards.select_race') %></option>
        <% PartyRewardEngine::RACES.each do |race| %>
          <option value="<%= race %>"><%= race %></option>
        <% end %>
      </select>
    </div>

    <div style="min-width:130px; flex:1.4;">
      <select name="party[characters_attributes][CHAR_IDX][character_class_id]" class="form-select form-select-sm char-class-select" required>
        <option value=""><%= t('party_rewards.select_class') %></option>
        <% character_classes.each do |cc| %>
          <option value="<%= cc.id %>"><%= cc.name %></option>
        <% end %>
      </select>
    </div>

    <div style="min-width:70px; flex:0.5;">
      <select name="party[characters_attributes][CHAR_IDX][level]" class="form-select form-select-sm">
        <% (1..20).each do |lvl| %>
          <option value="<%= lvl %>" <%= lvl == 5 ? 'selected' : '' %>><%= lvl %></option>
        <% end %>
      </select>
    </div>
  </div>
</template>

<script>
$(function() {
  function updateNoCharactersMsg() {
    const visible = $("#charactersList .character-row:visible").length;
    $("#noCharactersMsg").toggle(visible === 0);
  }

  $("#addCharacterBtn").on("click", function(e) {
    e.preventDefault();
    const tpl = document.getElementById("characterFieldTemplate");
    const html = tpl.innerHTML.replace(/CHAR_IDX/g, Date.now());
    const row = $(html);
    $("#charactersList").append(row);
    updateNoCharactersMsg();
  });

  $(document).on("click", ".remove-char-btn", function(e) {
    e.preventDefault();
    const row = $(this).closest(".character-row");
    const destroyField = row.find(".char-destroy-field");
    if (destroyField.length) {
      // Existing record: mark for destruction
      destroyField.val("1");
      row.hide();
    } else {
      row.remove();
    }
    updateNoCharactersMsg();
  });
});
</script>
