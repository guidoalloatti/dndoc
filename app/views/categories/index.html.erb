<div class="container mt-4">
  <%# ── Header ── %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0 fw-bold">
      <i class="bi bi-grid-3x3-gap text-primary me-1"></i> <%= t('categories.title') %>
      <span class="badge bg-primary rounded-pill ms-2 fs-6"><%= @pagy.count %></span>
    </h4>
    <%= link_to new_category_path, class: "btn btn-sm btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i><%= t('categories.new') %>
    <% end %>
  </div>

  <%# ── Filters bar ── %>
  <% has_filters = params[:q].present? %>
  <%= form_with url: categories_path, method: :get, local: true, id: "categories-filter-form" do %>
    <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
    <%= hidden_field_tag :dir, params[:dir] if params[:dir].present? %>
    <%= hidden_field_tag :per_page, params[:per_page] if params[:per_page].present? %>

    <div class="items-toolbar d-flex align-items-center border rounded mb-3">
      <i class="bi bi-search text-muted px-2"></i>
      <%= text_field_tag :q, params[:q],
        class: "items-toolbar-input flex-grow-1",
        placeholder: t('categories.search_placeholder'),
        id: "categories-search",
        autocomplete: "off" %>

      <% if has_filters %>
        <span class="items-toolbar-sep"></span>
        <%= link_to categories_path(sort: params[:sort], dir: params[:dir], per_page: params[:per_page]), class: "items-toolbar-clear text-muted px-2", title: t('items.clear') do %>
          <i class="bi bi-x-lg"></i>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# ── Sort bar ── %>
  <div class="d-flex align-items-center gap-3 mb-2">
    <span class="text-muted small fw-semibold text-uppercase" style="font-size: 0.65rem;">Sort:</span>
    <span style="font-size: 0.72rem;"><%= categories_sort_link(:name, t('shared.name')) %></span>
    <span style="font-size: 0.72rem;"><%= categories_sort_link(:min_weight, t('categories.min_weight')) %></span>
    <span style="font-size: 0.72rem;"><%= categories_sort_link(:max_weight, t('categories.max_weight')) %></span>
  </div>

  <%# ── Card Grid ── %>
  <% if @categories.any? %>
    <div class="row g-2">
      <% @categories.each do |category| %>
        <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
          <div class="index-card">
            <div class="d-flex justify-content-between align-items-start">
              <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-1">
                  <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                    <i class="bi bi-<%= category_icon(category.name) %> text-primary" style="font-size: 0.75rem;"></i>
                  </div>
                  <span class="card-title"><%= category.name %></span>
                </div>
                <% if category.description.present? %>
                  <p class="card-meta mb-1" style="line-height: 1.3;"><%= truncate(category.description, length: 70) %></p>
                <% end %>
              </div>
              <div class="card-actions">
                <%= link_to category_path(category), class: "action-icon text-primary", title: t('shared.show') do %><i class="bi bi-eye"></i><% end %>
                <%= link_to edit_category_path(category), class: "action-icon text-secondary", title: t('shared.edit') do %><i class="bi bi-pencil"></i><% end %>
                <%= button_to category_path(category), method: :delete, data: { turbo_confirm: t('shared.confirm_delete') }, class: "action-icon text-danger", title: t('shared.delete') do %><i class="bi bi-trash3"></i><% end %>
              </div>
            </div>
            <div class="card-stats">
              <span class="stat-item"><i class="bi bi-feather"></i> <%= category.min_weight %>–<%= category.max_weight %> lbs</span>
              <span class="stat-item"><i class="bi bi-box-seam"></i> <%= category.items.size %> <%= t('categories.items_count') %></span>
              <span class="stat-item"><i class="bi bi-magic"></i> <%= category.effects.size %> <%= t('categories.effects_count') %></span>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── Pagination ── %>
    <nav class="d-flex align-items-center justify-content-between mt-3 mb-4">
      <div class="d-flex align-items-center gap-2">
        <small class="text-muted">
          <%= t('categories.showing', from: @pagy.from, to: @pagy.to, count: @pagy.count) %>
        </small>
        <span class="text-muted small">·</span>
        <div class="d-flex align-items-center gap-1">
          <% [20, 50, 100].each do |n| %>
            <% active = (@pagy.limit == n) %>
            <%= link_to n,
              categories_path(request.params.except("controller", "action").merge(per_page: n, page: nil)),
              class: "btn btn-outline-secondary py-0 px-1 #{'active' if active}",
              style: "font-size: 0.7rem;" %>
          <% end %>
          <span class="text-muted" style="font-size: 0.7rem;"><%= t('categories.per_page') %></span>
        </div>
      </div>
      <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
    </nav>
  <% else %>
    <div class="text-center py-5">
      <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
      <p class="text-muted mt-2"><%= t('shared.no_records') %></p>
      <%= link_to new_category_path, class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i><%= t('categories.new') %>
      <% end %>
    </div>
  <% end %>
</div>

<script>
  function initCategoriesSearch() {
    var searchInput = document.getElementById("categories-search");
    var form = document.getElementById("categories-filter-form");
    if (!searchInput || !form || searchInput.dataset.bound) return;

    searchInput.dataset.bound = "true";
    var debounceTimer;

    searchInput.addEventListener("keyup", function() {
      clearTimeout(debounceTimer);
      var value = searchInput.value.trim();

      debounceTimer = setTimeout(function() {
        if (value.length >= 3 || value.length === 0) {
          form.requestSubmit();
        }
      }, 300);
    });
  }

  document.addEventListener("DOMContentLoaded", initCategoriesSearch);
  document.addEventListener("turbo:load", initCategoriesSearch);
</script>
