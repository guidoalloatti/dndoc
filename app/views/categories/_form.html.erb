<%= form_with(model: @category, local: true) do |form| %>
  <% if @category.errors.any? %>
    <div class="alert alert-danger py-2 small">
      <i class="bi bi-exclamation-triangle me-1"></i>
      <strong><%= pluralize(@category.errors.count, "error") %>:</strong>
      <ul class="mb-0 mt-1">
        <% @category.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="mb-3">
        <%= form.label :name, t('shared.name'), class: "form-label small fw-semibold" %>
        <%= form.text_field :name, class: "form-control form-control-sm", placeholder: "Category name" %>
      </div>

      <div class="mb-3">
        <%= form.label :description, t('shared.description'), class: "form-label small fw-semibold" %>
        <%= form.text_area :description, class: "form-control form-control-sm", rows: 3, placeholder: "Describe the category..." %>
      </div>

      <h6 class="text-muted text-uppercase small fw-semibold mb-2">
        <i class="bi bi-speedometer me-1"></i> <%= t('items.weight') %>
      </h6>
      <div class="row g-3 mb-0">
        <div class="col-sm-6">
          <%= form.label :min_weight, t('categories.min_weight'), class: "form-label small fw-semibold" %>
          <%= form.number_field :min_weight, class: "form-control form-control-sm", min: 0, placeholder: "0" %>
        </div>
        <div class="col-sm-6">
          <%= form.label :max_weight, t('categories.max_weight'), class: "form-label small fw-semibold" %>
          <%= form.number_field :max_weight, class: "form-control form-control-sm", min: 0, placeholder: "100" %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <%= form.submit @category.persisted? ? t('shared.update') : t('shared.create'), class: "btn btn-sm btn-primary" %>
    <%= link_to t('shared.cancel'), categories_path, class: "btn btn-sm btn-outline-secondary" %>
  </div>
<% end %>
