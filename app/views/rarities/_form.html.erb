<%= form_with(model: @rarity, local: true) do |form| %>
  <% if @rarity.errors.any? %>
    <div class="alert alert-danger py-2 small">
      <i class="bi bi-exclamation-triangle me-1"></i>
      <strong><%= pluralize(@rarity.errors.count, "error") %>:</strong>
      <ul class="mb-0 mt-1">
        <% @rarity.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="mb-3">
        <%= form.label :name, t('shared.name'), class: "form-label small fw-semibold" %>
        <%= form.text_field :name, class: "form-control form-control-sm", placeholder: "e.g. Legendary" %>
      </div>

      <h6 class="text-muted text-uppercase small fw-semibold mb-2">
        <i class="bi bi-coin me-1"></i> <%= t('items.price') %>
      </h6>
      <div class="row g-3 mb-3">
        <div class="col-sm-6">
          <%= form.label :min_price, t('rarities.min_price'), class: "form-label small fw-semibold" %>
          <%= form.number_field :min_price, class: "form-control form-control-sm", min: 0, placeholder: "0" %>
        </div>
        <div class="col-sm-6">
          <%= form.label :max_price, t('rarities.max_price'), class: "form-label small fw-semibold" %>
          <%= form.number_field :max_price, class: "form-control form-control-sm", min: 0, placeholder: "10000" %>
        </div>
      </div>

      <h6 class="text-muted text-uppercase small fw-semibold mb-2">
        <i class="bi bi-lightning-charge me-1"></i> <%= t('items.power') %>
      </h6>
      <div class="row g-3 mb-0">
        <div class="col-sm-6">
          <%= form.label :min_power, t('rarities.min_power'), class: "form-label small fw-semibold" %>
          <%= form.number_field :min_power, class: "form-control form-control-sm", min: 0, max: 10, placeholder: "0" %>
        </div>
        <div class="col-sm-6">
          <%= form.label :max_power, t('rarities.max_power'), class: "form-label small fw-semibold" %>
          <%= form.number_field :max_power, class: "form-control form-control-sm", min: 0, max: 10, placeholder: "10" %>
        </div>
      </div>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <%= form.submit @rarity.persisted? ? t('shared.update') : t('shared.create'), class: "btn btn-sm btn-primary" %>
    <%= link_to t('shared.cancel'), rarities_path, class: "btn btn-sm btn-outline-secondary" %>
  </div>
<% end %>
