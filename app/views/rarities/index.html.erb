<div class="container mt-4">
  <%# ── Header ── %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0 fw-bold">
      <i class="bi bi-stars text-primary me-1"></i> <%= t('rarities.title') %>
      <span class="badge bg-primary rounded-pill ms-2 fs-6"><%= @pagy.count %></span>
    </h4>
    <%= link_to new_rarity_path, class: "btn btn-sm btn-primary" do %>
      <i class="bi bi-plus-lg me-1"></i><%= t('rarities.new') %>
    <% end %>
  </div>

  <%# ── Filters bar ── %>
  <% has_filters = params[:q].present? %>
  <%= form_with url: rarities_path, method: :get, local: true, id: "rarities-filter-form" do %>
    <%= hidden_field_tag :sort, params[:sort] if params[:sort].present? %>
    <%= hidden_field_tag :dir, params[:dir] if params[:dir].present? %>
    <%= hidden_field_tag :per_page, params[:per_page] if params[:per_page].present? %>

    <div class="items-toolbar d-flex align-items-center border rounded mb-3">
      <i class="bi bi-search text-muted px-2"></i>
      <%= text_field_tag :q, params[:q],
        class: "items-toolbar-input flex-grow-1",
        placeholder: t('rarities.search_placeholder'),
        id: "rarities-search",
        autocomplete: "off" %>

      <% if has_filters %>
        <span class="items-toolbar-sep"></span>
        <%= link_to rarities_path(sort: params[:sort], dir: params[:dir], per_page: params[:per_page]), class: "items-toolbar-clear text-muted px-2", title: t('items.clear') do %>
          <i class="bi bi-x-lg"></i>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <%# ── Card Grid ── %>
  <% if @rarities.any? %>
    <div class="row g-2">
      <% @rarities.each do |rarity| %>
        <% css = rarity_css_class(rarity.name) %>
        <div class="col-12 col-sm-6 col-lg-4">
          <div class="index-card rarity-card-<%= css %> rarity-<%= css %>">
            <div class="d-flex justify-content-between align-items-start">
              <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <span class="badge <%= rarity_badge_class(rarity.name) %>" style="font-size: 0.72rem;"><i class="bi bi-star-fill me-1"></i><%= rarity.name %></span>
                </div>
                <div class="row g-2">
                  <div class="col-6">
                    <div class="small text-muted fw-semibold" style="font-size: 0.6rem; text-transform: uppercase;"><i class="bi bi-coin me-1"></i><%= t('rarities.price_range') %></div>
                    <div class="fw-semibold" style="font-size: 0.78rem;"><%= number_with_delimiter(rarity.min_price) %> – <%= number_with_delimiter(rarity.max_price) %> gp</div>
                  </div>
                  <div class="col-6">
                    <div class="small text-muted fw-semibold" style="font-size: 0.6rem; text-transform: uppercase;"><i class="bi bi-lightning-charge me-1"></i><%= t('rarities.power_range') %></div>
                    <div class="fw-semibold" style="font-size: 0.78rem;"><%= rarity.min_power %> – <%= rarity.max_power %></div>
                  </div>
                </div>
              </div>
              <div class="d-flex flex-column align-items-end gap-1">
                <div class="card-actions">
                  <%= link_to rarity_path(rarity), class: "action-icon text-primary", title: t('shared.show') do %><i class="bi bi-eye"></i><% end %>
                  <%= link_to edit_rarity_path(rarity), class: "action-icon text-secondary", title: t('shared.edit') do %><i class="bi bi-pencil"></i><% end %>
                  <%= button_to rarity_path(rarity), method: :delete, data: { turbo_confirm: t('shared.confirm_delete') }, class: "action-icon text-danger", title: t('shared.delete') do %><i class="bi bi-trash3"></i><% end %>
                </div>
                <span class="stat-item"><i class="bi bi-box-seam"></i> <%= rarity.items.size %> <%= t('rarities.items_count') %></span>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── Pagination ── %>
    <nav class="d-flex align-items-center justify-content-between mt-3 mb-4">
      <div class="d-flex align-items-center gap-2">
        <small class="text-muted">
          <%= t('rarities.showing', from: @pagy.from, to: @pagy.to, count: @pagy.count) %>
        </small>
        <span class="text-muted small">·</span>
        <div class="d-flex align-items-center gap-1">
          <% [20, 50, 100].each do |n| %>
            <% active = (@pagy.limit == n) %>
            <%= link_to n,
              rarities_path(request.params.except("controller", "action").merge(per_page: n, page: nil)),
              class: "btn btn-outline-secondary py-0 px-1 #{'active' if active}",
              style: "font-size: 0.7rem;" %>
          <% end %>
          <span class="text-muted" style="font-size: 0.7rem;"><%= t('rarities.per_page') %></span>
        </div>
      </div>
      <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
    </nav>
  <% else %>
    <div class="text-center py-5">
      <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
      <p class="text-muted mt-2"><%= t('shared.no_records') %></p>
      <%= link_to new_rarity_path, class: "btn btn-primary" do %>
        <i class="bi bi-plus-lg me-1"></i><%= t('rarities.new') %>
      <% end %>
    </div>
  <% end %>
</div>

<script>
  function initRaritiesSearch() {
    var searchInput = document.getElementById("rarities-search");
    var form = document.getElementById("rarities-filter-form");
    if (!searchInput || !form || searchInput.dataset.bound) return;

    searchInput.dataset.bound = "true";
    var debounceTimer;

    searchInput.addEventListener("keyup", function() {
      clearTimeout(debounceTimer);
      var value = searchInput.value.trim();

      debounceTimer = setTimeout(function() {
        if (value.length >= 3 || value.length === 0) {
          form.requestSubmit();
        }
      }, 300);
    });
  }

  document.addEventListener("DOMContentLoaded", initRaritiesSearch);
  document.addEventListener("turbo:load", initRaritiesSearch);
</script>
