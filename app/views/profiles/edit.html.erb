<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-header">
          <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i><%= t('profiles.edit_profile') %></h5>
        </div>
        <div class="card-body">
          <%= form_with(model: current_user, url: profile_path, method: :patch, multipart: true) do |f| %>
            <% if current_user.errors.any? %>
              <div class="alert alert-danger">
                <ul class="mb-0">
                  <% current_user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <div class="mb-4">
              <%= f.label :avatar, t('profiles.avatar'), class: 'form-label' %>
              <div class="d-flex align-items-center gap-3">
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, class: "rounded-circle object-fit-cover", width: 64, height: 64, alt: "Avatar" %>
                <% elsif current_user.avatar_url.present? %>
                  <img src="<%= current_user.avatar_url %>" class="rounded-circle object-fit-cover" width="64" height="64" alt="Avatar">
                <% else %>
                  <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 64px; height: 64px; font-size: 1.5rem;">
                    <%= current_user.initials %>
                  </div>
                <% end %>
                <div class="flex-grow-1">
                  <%= f.file_field :avatar, class: 'form-control', accept: 'image/jpeg,image/png,image/gif,image/webp' %>
                  <div class="form-text"><%= t('profiles.avatar_hint') %></div>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <%= f.label :first_name, t('profiles.first_name'), class: 'form-label' %>
              <%= f.text_field :first_name, class: 'form-control', placeholder: t('profiles.first_name') %>
            </div>

            <div class="mb-3">
              <%= f.label :last_name, t('profiles.last_name'), class: 'form-label' %>
              <%= f.text_field :last_name, class: 'form-control', placeholder: t('profiles.last_name') %>
            </div>

            <div class="mb-3">
              <%= f.label :email, t('profiles.email'), class: 'form-label' %>
              <%= f.email_field :email, class: 'form-control', placeholder: t('profiles.email') %>
            </div>

            <div class="d-flex gap-2">
              <%= f.submit t('shared.save'), class: 'btn btn-primary' %>
              <%= link_to t('shared.cancel'), profile_path, class: 'btn btn-outline-secondary' %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
