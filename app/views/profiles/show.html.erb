<div class="container py-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-body text-center py-5">
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar, class: "rounded-circle mb-3 object-fit-cover", width: 100, height: 100, alt: "Avatar" %>
          <% elsif current_user.avatar_url.present? %>
            <img src="<%= current_user.avatar_url %>" class="rounded-circle mb-3 object-fit-cover" width="100" height="100" alt="Avatar">
          <% else %>
            <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px; font-size: 2.5rem;">
              <%= current_user.initials %>
            </div>
          <% end %>
          <h3><%= current_user.full_name %></h3>
          <p class="text-muted"><%= current_user.email %></p>
          <% if current_user.provider.present? %>
            <span class="badge bg-info"><i class="bi bi-google me-1"></i> <%= t('profiles.linked_with_google') %></span>
          <% end %>
        </div>
      </div>

      <div class="card shadow-sm mt-4">
        <div class="card-header">
          <h5 class="mb-0"><i class="bi bi-person-lines-fill me-2"></i><%= t('profiles.details') %></h5>
        </div>
        <div class="card-body">
          <div class="row mb-3">
            <div class="col-sm-4 fw-semibold"><%= t('profiles.first_name') %></div>
            <div class="col-sm-8"><%= current_user.first_name || '-' %></div>
          </div>
          <div class="row mb-3">
            <div class="col-sm-4 fw-semibold"><%= t('profiles.last_name') %></div>
            <div class="col-sm-8"><%= current_user.last_name || '-' %></div>
          </div>
          <div class="row mb-3">
            <div class="col-sm-4 fw-semibold"><%= t('profiles.email') %></div>
            <div class="col-sm-8"><%= current_user.email %></div>
          </div>
          <div class="row mb-3">
            <div class="col-sm-4 fw-semibold"><%= t('profiles.member_since') %></div>
            <div class="col-sm-8"><%= current_user.created_at.strftime("%B %d, %Y") %></div>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2 mt-3">
        <%= link_to t('profiles.edit_profile'), edit_profile_path, class: 'btn btn-primary' %>
        <%= link_to t('shared.back'), root_path, class: 'btn btn-outline-secondary' %>
      </div>
    </div>
  </div>
</div>
